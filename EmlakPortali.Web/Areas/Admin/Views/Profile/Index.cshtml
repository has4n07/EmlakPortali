@{
    ViewData["Title"] = "Profilim";
}

<style>
    .avatar-wrap {
        position: relative;
        width: 120px;
        height: 120px;
        margin: 0 auto;
        cursor: pointer;
    }
    .avatar-wrap img {
        width: 120px;
        height: 120px;
        object-fit: cover;
        border-radius: 50%;
        border: 4px solid #fff;
        box-shadow: 0 4px 16px rgba(0,0,0,0.15);
        transition: filter 0.25s;
    }
    .avatar-wrap:hover img { filter: brightness(0.65); }
    .avatar-overlay {
        position: absolute;
        inset: 0;
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        background: rgba(79,70,229,0.35);
        opacity: 0;
        transition: opacity 0.25s;
        font-size: 1.6rem;
        color: #fff;
        pointer-events: none;
    }
    .avatar-wrap:hover .avatar-overlay { opacity: 1; }
    #uploadBar { display: none; }
</style>

<div class="container-fluid px-4 py-4">
    <div class="d-flex align-items-center justify-content-between mb-4">
        <div>
            <h3 class="fw-bold mb-1 text-gradient">Profil Yönetimi</h3>
            <div class="text-muted small">Kişisel bilgilerinizi ve profil fotoğrafınızı yönetin</div>
        </div>
        <a class="btn btn-outline-secondary" asp-area="Admin" asp-controller="Dashboard" asp-action="Index">
            <i class="ph ph-arrow-left"></i> Geri Dön
        </a>
    </div>

    <div class="row justify-content-center">
        <div class="col-lg-8">
            <div class="card shadow-md border-0">
                <div class="card-body p-5">
                    <div class="alert alert-danger d-none" id="errBox"></div>
                    <div class="alert alert-success d-none" id="okBox"></div>

                    <!-- Avatar Yükleme -->
                    <div class="text-center mb-4">
                        <div class="avatar-wrap" id="avatarWrap" title="Fotoğraf değiştir için tıkla">
                            <img id="avatarImg"
                                 src="https://ui-avatars.com/api/?name=Admin&background=4f46e5&color=fff&size=120"
                                 alt="Profil Fotoğrafı" />
                            <div class="avatar-overlay">
                                <i class="ph ph-camera-plus"></i>
                            </div>
                        </div>
                        <input type="file" id="avatarFile" accept=".jpg,.jpeg,.png,.webp" class="d-none" />

                        <!-- Upload progress -->
                        <div id="uploadBar" class="mt-2" style="max-width:200px;margin:0 auto;">
                            <div class="progress" style="height:4px;border-radius:4px;">
                                <div id="uploadProgress" class="progress-bar bg-primary" style="width:0%;transition:width 0.3s;"></div>
                            </div>
                            <div class="text-muted small mt-1">Yükleniyor...</div>
                        </div>

                        <div class="text-muted small mt-2">
                            <i class="ph ph-info"></i> Fotoğrafa tıklayarak değiştirebilirsiniz
                        </div>
                    </div>

                    <div class="row g-4">
                        <div class="col-md-6">
                            <label class="form-label fw-semibold">E-posta <span class="text-danger">*</span></label>
                            <div class="input-group">
                                <span class="input-group-text bg-light"><i class="ph ph-envelope"></i></span>
                                <input class="form-control bg-light" id="email" disabled />
                            </div>
                        </div>

                        <div class="col-md-6">
                            <label class="form-label fw-semibold">Ad Soyad</label>
                            <div class="input-group">
                                <span class="input-group-text bg-light"><i class="ph ph-user"></i></span>
                                <input class="form-control" id="fullName" placeholder="Ad Soyadınızı girin" />
                            </div>
                        </div>

                        <div class="col-md-6">
                            <label class="form-label fw-semibold">Telefon Numarası</label>
                            <div class="input-group">
                                <span class="input-group-text bg-light"><i class="ph ph-phone"></i></span>
                                <input class="form-control" id="phoneNumber" placeholder="555-000-0000" />
                            </div>
                        </div>

                        <div class="col-md-6 d-flex align-items-end">
                            <button class="btn btn-primary w-100 py-2 fw-semibold shadow-sm" id="btnSave" type="button">
                                <i class="ph ph-floppy-disk me-2"></i> Değişiklikleri Kaydet
                            </button>
                        </div>
                    </div>

                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        $(function () {
            // Mevcut profil fotoğrafı URL'si bellekte tutulur
            let _currentPpUrl = "";

            function setErr(msg) {
                if (!msg) { $("#errBox").addClass("d-none").text(""); return; }
                $("#errBox").removeClass("d-none").text(msg);
                $("#okBox").addClass("d-none");
            }
            function setOk(msg) {
                if (!msg) { $("#okBox").addClass("d-none").text(""); return; }
                $("#okBox").removeClass("d-none").text(msg);
                $("#errBox").addClass("d-none");
            }

            function setAvatar(url, name) {
                const safeName = encodeURIComponent(name || "Admin");
                const fallback = "https://ui-avatars.com/api/?name=" + safeName + "&background=4f46e5&color=fff&size=120";
                const src = url ? url : fallback;
                $("#avatarImg").attr("src", src);
                $("#avatarImg").off("error").on("error", function () {
                    $(this).off("error").attr("src", fallback);
                });
            }

            // ── Avatar tıklama → dosya seç ──────────────────────
            $("#avatarWrap").on("click", function () {
                $("#avatarFile").trigger("click");
            });

            // ── Dosya seçilince yükle ────────────────────────────
            $("#avatarFile").on("change", async function () {
                const file = this.files && this.files[0];
                if (!file) return;

                // Anlık önizleme
                const objectUrl = URL.createObjectURL(file);
                $("#avatarImg").attr("src", objectUrl);

                // Progress bar göster
                $("#uploadBar").show();
                $("#uploadProgress").css("width", "30%");
                setErr(null); setOk(null);

                try {
                    $("#uploadProgress").css("width", "60%");

                    // Dosya yükle
                    const uploadRes = await AdminApi.upload("/api/listings/upload-image", file);
                    const uploadedUrl = uploadRes?.data?.url
                        || uploadRes?.data?.Url
                        || uploadRes?.Data?.url
                        || uploadRes?.Data?.Url
                        || uploadRes?.url
                        || uploadRes?.Url;

                    if (!uploadedUrl) throw new Error("Sunucudan URL alınamadı.");

                    $("#uploadProgress").css("width", "85%");

                    // Profili güncelle
                    await AdminApi.put("/api/profile", {
                        fullName: $("#fullName").val(),
                        phoneNumber: $("#phoneNumber").val(),
                        profilePictureUrl: uploadedUrl
                    });

                    _currentPpUrl = uploadedUrl;
                    $("#uploadProgress").css("width", "100%");
                    setAvatar(uploadedUrl, $("#fullName").val());
                    setOk("Profil fotoğrafı güncellendi.");

                } catch (e) {
                    setErr("Fotoğraf yüklenemedi: " + (e?.message ?? String(e)));
                    // Hatalıysa önceki avatara dön
                    setAvatar(_currentPpUrl, $("#fullName").val());
                } finally {
                    setTimeout(function () { $("#uploadBar").hide(); }, 800);
                    // File input'u sıfırla (aynı dosyayı tekrar seçebilsin)
                    this.value = "";
                }
            });

            // ── Profil yükle ─────────────────────────────────────
            async function load() {
                setErr(null); setOk(null);
                try {
                    const res = await AdminApi.get("/api/profile/me");
                    const u = res?.data || res?.Data || {};
                    $("#email").val(u.email ?? u.Email ?? "");
                    $("#fullName").val(u.fullName ?? u.FullName ?? "");
                    $("#phoneNumber").val(u.phoneNumber ?? u.PhoneNumber ?? "");

                    _currentPpUrl = (u.profilePictureUrl ?? u.ProfilePictureUrl ?? "").toString().trim();
                    setAvatar(_currentPpUrl, u.fullName ?? u.FullName);
                } catch (e) {
                    setErr(e?.message ?? "Oturum yoksa önce giriş yap.");
                }
            }

            // ── Profil kaydet ─────────────────────────────────────
            $("#btnSave").on("click", async function () {
                setErr(null); setOk(null);
                const btn = $(this);
                const og = btn.html();
                btn.prop("disabled", true).html('<span class="spinner-border spinner-border-sm me-2"></span> Kaydediliyor...');
                try {
                    await AdminApi.put("/api/profile", {
                        fullName: $("#fullName").val(),
                        phoneNumber: $("#phoneNumber").val(),
                        profilePictureUrl: _currentPpUrl || null
                    });
                    setOk("Profil başarıyla güncellendi.");
                } catch (e) {
                    setErr(e?.message ?? String(e));
                } finally {
                    btn.prop("disabled", false).html(og);
                }
            });

            // ── Init ──────────────────────────────────────────────
            (async function init() { await load(); })();
        });
    </script>
}
