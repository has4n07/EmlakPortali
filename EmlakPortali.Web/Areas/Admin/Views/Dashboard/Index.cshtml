@{
    ViewData["Title"] = "Dashboard";
}

<div class="d-flex align-items-center justify-content-between mb-4">
    <div>
        <h2 class="mb-1 text-gradient">Dashboard Özeti</h2>
        <p class="text-muted mb-0">Sistemin genel durumunu ve istatistiklerini buradan takip edebilirsiniz.</p>
    </div>
    <div class="text-end d-none d-md-block">
        <div class="small text-muted fw-semibold mb-1">Oturum Durumu</div>
        <div id="adminSessionBadge" class="badge bg-secondary p-2 px-3 rounded-pill shadow-sm">Bağlanıyor...</div>
    </div>
</div>

<div class="row g-4 mb-5">
    <!-- Stat Card 1 -->
    <div class="col-sm-6 col-xl-3">
        <div class="card stat-card h-100 p-2">
            <div class="card-body d-flex align-items-center justify-content-between">
                <div>
                    <p class="text-muted fw-semibold mb-1 small text-uppercase tracking-wide">Toplam İlan</p>
                    <h3 class="fw-bold mb-0 text-dark" id="statTotalListings">-</h3>
                </div>
                <div class="stat-icon bg-primary bg-opacity-10 text-primary">
                    <i class="ph ph-buildings fs-2"></i>
                </div>
            </div>
        </div>
    </div>
    
    <!-- Stat Card 2 -->
    <div class="col-sm-6 col-xl-3">
        <div class="card stat-card h-100 p-2 border-0">
            <div class="card-body d-flex align-items-center justify-content-between">
                <div>
                    <p class="text-warning fw-semibold mb-1 small text-uppercase tracking-wide">Onay Bekleyen</p>
                    <h3 class="fw-bold mb-0 text-dark" id="statPendingListings">-</h3>
                </div>
                <div class="stat-icon bg-warning bg-opacity-10 text-warning">
                    <i class="ph ph-clock fs-2"></i>
                </div>
            </div>
            <!-- Subtly highlight the border bottom -->
            <div class="bg-warning position-absolute bottom-0 start-0 w-100" style="height: 3px; border-radius: 0 0 1rem 1rem;"></div>
        </div>
    </div>

    <!-- Stat Card 3 -->
    <div class="col-sm-6 col-xl-3">
        <div class="card stat-card h-100 p-2">
            <div class="card-body d-flex align-items-center justify-content-between">
                <div>
                    <p class="text-success fw-semibold mb-1 small text-uppercase tracking-wide">Aktif Yayın</p>
                    <h3 class="fw-bold mb-0 text-dark" id="statActiveListings">-</h3>
                </div>
                <div class="stat-icon bg-success bg-opacity-10 text-success">
                    <i class="ph ph-check-circle fs-2"></i>
                </div>
            </div>
        </div>
    </div>

    <!-- Stat Card 4 -->
    <div class="col-sm-6 col-xl-3">
        <div class="card stat-card h-100 p-2">
            <div class="card-body d-flex align-items-center justify-content-between">
                <div>
                    <p class="text-info fw-semibold mb-1 small text-uppercase tracking-wide">Toplam Kullanıcı</p>
                    <h3 class="fw-bold mb-0 text-dark" id="statTotalUsers">-</h3>
                </div>
                <div class="stat-icon bg-info bg-opacity-10 text-info">
                    <i class="ph ph-users-three fs-2"></i>
                </div>
            </div>
        </div>
    </div>
</div>

<div class="row g-4">
    <div class="col-lg-8">
        <div class="card shadow-sm h-100 border-0">
            <div class="card-header bg-white pt-4 pb-3 border-0">
                <h5 class="fw-bold mb-0">Sistem Tanıtımı</h5>
            </div>
            <div class="card-body">
                <p class="text-muted">Bu portal, en gelişmiş emlak yönetim teknolojilerini sunarak sistem yöneticilerinin ilanları ve kullanıcıları zahmetsizce yönetmesine imkan tanır. Emlak Portalı API altyapısı sayesinde işlemler son derece hızlı ve güvenilirdir.</p>
                
                <div class="d-flex gap-3 mt-4">
                    <a class="btn btn-primary d-flex align-items-center gap-2" asp-area="Admin" asp-controller="Listings" asp-action="Index">
                        <i class="ph ph-list-magnifying-glass fs-5"></i> İlanları Yönet
                    </a>
                    <a class="btn btn-outline-secondary d-flex align-items-center gap-2" asp-area="Admin" asp-controller="Users" asp-action="Index">
                        <i class="ph ph-user-gear fs-5"></i> Kullanıcı Ayarları
                    </a>
                </div>
            </div>
        </div>
    </div>
    
    <div class="col-lg-4">
        <div class="card shadow-sm h-100 border-0 bg-primary text-white text-center" style="background: linear-gradient(135deg, var(--primary-color), #8b5cf6);">
            <div class="card-body d-flex flex-column align-items-center justify-content-center p-5">
                <div class="mb-4 bg-white bg-opacity-25 rounded-circle d-flex align-items-center justify-content-center" style="width: 80px; height: 80px;">
                    <i class="ph ph-shield-star fs-1 text-white"></i>
                </div>
                <h4 class="fw-bold text-white mb-2">Yetkilendirme</h4>
                <p class="text-white-50 small mb-4">API tabanlı JWT Tokens üzerinden güvenli erişim sağlanmaktadır.</p>
                <a class="btn btn-light rounded-pill px-4 text-primary fw-semibold" asp-area="Admin" asp-controller="Roles" asp-action="Index">Rolleri İncele</a>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        $(async function () {
            async function refreshSessionBadge() {
                const token = AdminAuth.getToken();
                if (!token) {
                    $("#adminSessionBadge")
                        .removeClass()
                        .addClass("badge bg-danger bg-opacity-10 text-danger border border-danger border-opacity-25 p-2 px-3 rounded-pill shadow-sm")
                        .html('<i class="ph ph-warning-circle me-1"></i> Oturum Kapalı');
                    return;
                }
                $("#adminSessionBadge")
                    .removeClass()
                    .addClass("badge bg-success bg-opacity-10 text-success border border-success border-opacity-25 p-2 px-3 rounded-pill shadow-sm")
                    .html('<i class="ph ph-shield-check me-1"></i> Oturum Aktif');
            }

            await refreshSessionBadge();

            try {
                const res = await AdminApi.get("/api/admin/dashboard/stats");
                const d = res?.data || res?.Data || {};
                
                // Animate numbers
                function animateValue(id, start, end, duration) {
                    if (start === end) return;
                    let range = end - start;
                    let current = start;
                    let increment = end > start ? 1 : -1;
                    let stepTime = Math.abs(Math.floor(duration / range));
                    let obj = document.getElementById(id);
                    let timer = setInterval(function() {
                        current += increment;
                        obj.innerHTML = current;
                        if (current == end) {
                            clearInterval(timer);
                        }
                    }, stepTime < 10 ? 10 : stepTime);
                }

                if (d) {
                    animateValue("statTotalListings", 0, d.totalListings ?? d.TotalListings ?? 0, 1000);
                    animateValue("statPendingListings", 0, d.pendingListings ?? d.PendingListings ?? 0, 800);
                    animateValue("statActiveListings", 0, d.activeListings ?? d.ActiveListings ?? 0, 900);
                    
                    const tUsers = d.totalUsers ?? d.TotalUsers;
                    if (tUsers !== null && tUsers !== undefined) {
                        animateValue("statTotalUsers", 0, tUsers, 1000);
                    } else {
                        $("#statTotalUsers").closest(".col-xl-3").hide();
                    }
                }
            } catch {
                // Sessiz geç
            }
            
            const cached = window.AdminAuth?.getUserInfo?.();
            if (cached) {
                const roles = cached.roles || cached.Roles || [];
                if (roles.includes("Realtor") && !roles.includes("Admin")) {
                    $("#statTotalUsers").closest(".col-xl-3").hide();
                }
            }
        });
    </script>
}
