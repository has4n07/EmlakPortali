@{
    ViewData["Title"] = "Ana Sayfa";
}

<!-- Hero Section -->
<div class="py-5 mb-5 animate-fade-in-up">
    <div class="row align-items-center g-5">
        <div class="col-lg-6">
            <h1 class="display-4 fw-bolder mb-4" style="font-family: 'Outfit', sans-serif;">
                Hayalindeki Evi <br/>
                <span class="text-gradient">Gelecekte Bul</span>
            </h1>
            <p class="lead text-muted mb-4">
                Satılık ve kiralık ilanları tek yerden kolayca filtrele, detayları incele ve favorilerine ekle. Modern arayüzümüzle yeni evini hemen keşfet.
            </p>
            <a href="/Listings" class="btn btn-futuristic px-5 py-3 rounded-pill shadow-lg">Keşfetmeye Başla</a>
        </div>
        <div class="col-lg-6">
            <div class="glass-panel p-4 p-md-5 delay-100 animate-fade-in-up">
                <h4 class="mb-4 text-white" style="font-family: 'Outfit', sans-serif;">
                    <i class="bi bi-search text-gradient"></i> Hızlı Arama
                </h4>
                <div class="row g-3">
                    <div class="col-12 col-md-6">
                        <label class="form-label small mb-1 text-muted">Şehir</label>
                        <select class="form-select" id="cityHome"></select>
                    </div>
                    <div class="col-12 col-md-6">
                        <label class="form-label small mb-1 text-muted">İlçe</label>
                        <select class="form-select" id="districtHome"></select>
                    </div>
                    <div class="col-12 col-md-12">
                        <label class="form-label small mb-1 text-muted">Tür</label>
                        <select class="form-select" id="listingTypeHome">
                            <option value="">Tümü</option>
                            <option value="1">Satılık</option>
                            <option value="2">Kiralık</option>
                        </select>
                    </div>
                    <div class="col-6">
                        <label class="form-label small mb-1 text-muted">Min Fiyat (₺)</label>
                        <input type="number" class="form-control" id="minPriceHome" placeholder="0" />
                    </div>
                    <div class="col-6">
                        <label class="form-label small mb-1 text-muted">Max Fiyat (₺)</label>
                        <input type="number" class="form-control" id="maxPriceHome" placeholder="Limit yok" />
                    </div>
                </div>
                <div class="d-grid gap-2 mt-4">
                    <button class="btn btn-futuristic w-100 py-2" id="btnSearchHome" type="button">Ev Bul</button>
                    <button class="btn btn-outline-futuristic w-100 py-2" id="btnClearHome" type="button">Filtreleri Temizle</button>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Featured Section -->
<div class="mb-5 delay-200 animate-fade-in-up">
    <div class="d-flex justify-content-between align-items-end mb-4 border-bottom pb-2" style="border-color: rgba(255,255,255,0.1) !important;">
        <h3 class="mb-0" style="font-family: 'Outfit', sans-serif;">Öne Çıkan <span class="text-gradient">İlanlar</span></h3>
        <a href="/Listings" class="text-decoration-none text-muted small hover-cyan">Tümünü Gör &rarr;</a>
    </div>
    
    <div id="featuredErr" class="alert alert-danger d-none glass-panel"></div>
    <div class="row g-4" id="featuredRows">
        <div class="col-12 text-center text-muted py-5">
            <div class="spinner-border text-info" role="status"></div>
            <div class="mt-2">Yükleniyor...</div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        const PublicApi = (function () {
            const baseUrl = "https://localhost:7293";
            async function request(method, url) {
                const res = await fetch(baseUrl + url);
                const text = await res.text();
                let json = null;
                try { json = text ? JSON.parse(text) : null; } catch { }
                if (!res.ok) {
                    const msg = json?.message || json?.Message || text || (res.status + " " + res.statusText);
                    throw new Error(msg);
                }
                return json;
            }
            return {
                get: (url) => request("GET", url)
            };
        })();

        $(function () {
            async function loadCities() {
                const res = await PublicApi.get("/api/lookups/cities");
                const list = res?.data || res?.Data || [];
                $("#cityHome").html('<option value="">Şehir Seçin</option>' +
                    list.map(c => `<option value="${c.id ?? c.Id}">${c.name ?? c.Name}</option>`).join(""));
            }

            $("#cityHome").on("change", async function () {
                const cityId = $(this).val();
                if (!cityId) {
                    $("#districtHome").html('<option value="">İlçe Seçin</option>');
                    return;
                }
                const res = await PublicApi.get(`/api/lookups/cities/${cityId}/districts`);
                const list = res?.data || res?.Data || [];
                $("#districtHome").html('<option value="">İlçe Seçin</option>' +
                    list.map(d => `<option value="${d.id ?? d.Id}">${d.name ?? d.Name}</option>`).join(""));
            });

            function setFeaturedErr(msg) {
                if (!msg) { $("#featuredErr").addClass("d-none").text(""); return; }
                $("#featuredErr").removeClass("d-none").text(msg);
            }

            async function loadFeatured() {
                setFeaturedErr(null);
                try {
                    const res = await PublicApi.get("/api/listings?take=6");
                    const items = res?.data || res?.Data || [];
                    if (!items.length) {
                        $("#featuredRows").html('<div class="col-12 text-muted text-center py-5 glass-panel">Gösterilecek ilan bulunamadı.</div>');
                        return;
                    }
                    const html = items.map((x, i) => {
                        const id = x.id ?? x.Id;
                        const title = x.title ?? x.Title;
                        const price = x.price ?? x.Price;
                        const city = x.cityName ?? x.CityName;
                        const district = x.districtName ?? x.DistrictName;
                        const img = imgUrl(x.coverImageUrl ?? x.CoverImageUrl, "https://picsum.photos/seed/" + id + "/600/400");
                        
                        return `
                        <div class="col-sm-6 col-lg-4 animate-fade-in-up" style="animation-delay: ${100 + i * 50}ms">
                            <a href="/Listings/Details/${id}" class="text-decoration-none text-main">
                                <div class="futuristic-card h-100">
                                    <div class="card-img-wrapper" style="height:220px;">
                                        <img src="${img}" class="w-100 h-100" loading="lazy" decoding="async" style="object-fit:cover;">
                                        <div class="price-badge">${price?.toLocaleString?.("tr-TR") ?? price} ₺</div>
                                    </div>
                                    <div class="p-4 d-flex flex-column h-100">
                                        <h5 class="fw-bold mb-2 text-white text-truncate">${title}</h5>
                                        <div class="text-muted small mb-3">
                                            <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" fill="currentColor" class="bi bi-geo-alt me-1 text-info" viewBox="0 0 16 16">
                                              <path d="M12.166 8.94c-.524 1.062-1.234 2.12-1.96 3.07A31.493 31.493 0 0 1 8 14.58a31.481 31.481 0 0 1-2.206-2.57c-.726-.95-1.436-2.008-1.96-3.07C3.304 7.867 3 6.862 3 6a5 5 0 0 1 10 0c0 .862-.305 1.867-.834 2.94zM8 16s6-5.686 6-10A6 6 0 0 0 2 6c0 4.314 6 10 6 10z"/>
                                              <path d="M8 8a2 2 0 1 1 0-4 2 2 0 0 1 0 4zm0 1a3 3 0 1 0 0-6 3 3 0 0 0 0 6z"/>
                                            </svg>
                                            ${city ?? ""} ${district ? " / " + district : ""}
                                        </div>
                                        <div class="mt-auto">
                                            <span class="btn btn-outline-futuristic btn-sm w-100">Detayları İncele</span>
                                        </div>
                                    </div>
                                </div>
                            </a>
                        </div>`;
                    }).join("");
                    $("#featuredRows").html(html);
                } catch (e) {
                    setFeaturedErr(e?.message ?? String(e));
                }
            }

            $("#btnSearchHome").on("click", function () {
                const qs = new URLSearchParams();
                const cityId = $("#cityHome").val();
                const districtId = $("#districtHome").val();
                const lt = $("#listingTypeHome").val();
                const min = $("#minPriceHome").val();
                const max = $("#maxPriceHome").val();

                if (cityId) qs.set("cityId", cityId);
                if (districtId) qs.set("districtId", districtId);
                if (lt) qs.set("listingType", lt);
                if (min) qs.set("minPrice", min);
                if (max) qs.set("maxPrice", max);

                window.location.href = "/Listings?" + qs.toString();
            });

            $("#btnClearHome").on("click", function () {
                $("#cityHome").val("");
                $("#districtHome").html('<option value="">İlçe Seçin</option>');
                $("#listingTypeHome").val("");
                $("#minPriceHome").val("");
                $("#maxPriceHome").val("");
            });

            (async function init() {
                await loadCities();
                await loadFeatured();
            })();
        });
    </script>
}