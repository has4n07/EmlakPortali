@{
    ViewData["Title"] = "Emlak Haberleri - Emlak Portali";
    var newsElement = ViewBag.News as System.Text.Json.JsonElement?;
    var found = newsElement.HasValue && newsElement.Value.ValueKind != System.Text.Json.JsonValueKind.Undefined;
}

@if (!found)
{
    <div class="text-center py-5">
        <div style="font-size:4rem;">??</div>
        <h4 class="mt-3">Haber bulunamadý</h4>
        <a href="/News" class="btn btn-outline-futuristic mt-3">Tüm Haberlere Dön</a>
    </div>
}
else
{
    var title = newsElement.Value.GetProperty("title").GetString();
    var category = newsElement.Value.GetProperty("category").GetString();
    var created = newsElement.Value.GetProperty("created").GetDateTime();
    var readMin = newsElement.Value.GetProperty("readMinutes").GetInt32();
    var img = newsElement.Value.GetProperty("imageUrl").GetString();
    var content = newsElement.Value.GetProperty("content").GetString();
    
    <div class="animate-fade-in-up" style="max-width:860px; margin:0 auto;">
        <!-- Breadcrumb -->
        <nav aria-label="breadcrumb" class="mb-4">
            <ol class="breadcrumb">
                <li class="breadcrumb-item"><a href="/" class="text-gradient text-decoration-none">Ana Sayfa</a></li>
                <li class="breadcrumb-item"><a href="/News" class="text-gradient text-decoration-none">Haberler</a></li>
                <li class="breadcrumb-item active text-muted">@title</li>
            </ol>
        </nav>

        <!-- Kategori + Meta -->
        <div class="d-flex gap-2 align-items-center mb-3 flex-wrap">
            <span class="badge px-3 py-2" style="background:linear-gradient(135deg,var(--accent-cyan),var(--accent-purple));border-radius:20px;">@category</span>
            <span class="text-muted small"><i class="bi bi-calendar3 me-1"></i>@created.ToString("d MMMM yyyy", new System.Globalization.CultureInfo("tr-TR"))</span>
            <span class="text-muted small"><i class="bi bi-clock me-1"></i>@readMin dk okuma</span>
        </div>

        <!-- Baţlýk -->
        <h1 class="fw-bold mb-4" style="font-family:'Outfit',sans-serif; line-height:1.3; font-size:2rem;">
            @title
        </h1>

        <!-- Kapak Görseli -->
        <div class="futuristic-card overflow-hidden mb-5">
            <img src="@img" class="w-100" style="height:380px;object-fit:cover;"
                 alt="@title" onerror="this.src='https://placehold.co/860x380/1a1f2e/00d4ff?text=Haber'">
        </div>

        <!-- Ýçerik -->
        <div class="glass-panel p-4 p-lg-5 mb-5">
            <div class="news-content lh-lg" style="color:var(--text-muted);">
                @Html.Raw(content)
            </div>
        </div>

        <!-- Geri Dön -->
        <div class="text-center">
            <a href="/News" class="btn btn-outline-futuristic px-5">
                <i class="bi bi-arrow-left me-2"></i>Tüm Haberlere Dön
            </a>
        </div>
    </div>
}

<style>
    .news-content h4 { color: var(--text-primary); font-family: 'Outfit', sans-serif; margin-top: 2rem; margin-bottom: 1rem; }
    .news-content p { margin-bottom: 1.2rem; }
</style>
