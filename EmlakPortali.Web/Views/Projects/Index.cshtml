@{
    ViewData["Title"] = "Projeler - Emlak Portali";
    var projects = new[]
    {
        new { Slug="panorama-istanbul", Name="Panorama Istanbul", City="Istanbul", Units=450, Delivery="2026 Q3", MinPrice="4.500.000", Status="Satista", Img="https://images.unsplash.com/photo-1545324418-cc1a3fa10c00?w=600&q=80", CityTag="istanbul" },
        new { Slug="capital-residence", Name="Capital Residence", City="Ankara", Units=280, Delivery="2025 Teslim", MinPrice="2.800.000", Status="On Satis", Img="https://images.unsplash.com/photo-1486325212027-8081e485255e?w=600&q=80", CityTag="ankara" },
        new { Slug="ege-park", Name="Ege Park Villalari", City="Izmir", Units=120, Delivery="2026 Q1", MinPrice="8.200.000", Status="Satista", Img="https://images.unsplash.com/photo-1512917774080-9991f1c4c750?w=600&q=80", CityTag="izmir" },
        new { Slug="bogazici-towers", Name="Bogazici Towers", City="Istanbul", Units=890, Delivery="2027 Q2", MinPrice="12.000.000", Status="On Satis", Img="https://images.unsplash.com/photo-1460472178825-e5240623afd5?w=600&q=80", CityTag="istanbul" },
        new { Slug="riviera-homes", Name="Riviera Homes", City="Antalya", Units=200, Delivery="2025 Teslim", MinPrice="6.500.000", Status="Satista", Img="https://images.unsplash.com/photo-1564013799919-ab600027ffc6?w=600&q=80", CityTag="antalya" },
        new { Slug="greenvalley-kagithane", Name="Green Valley Kagithane", City="Istanbul", Units=340, Delivery="2026 Q4", MinPrice="5.100.000", Status="On Satis", Img="https://images.unsplash.com/photo-1600596542815-ffad4c1539a9?w=600&q=80", CityTag="istanbul" },
    };
}

<div class="text-center mb-5" style="padding-top:20px;">
    <h1 class="fw-bold mb-2" style="font-family:'Outfit',sans-serif; font-size:2.5rem;">
        Seckin <span class="text-gradient">Konut Projeleri</span>
    </h1>
    <p class="text-muted fs-5">Turkiye'nin en prestijli gayrimenkul projelerini kesfedin</p>
</div>

<div class="glass-panel p-3 mb-5">
    <div class="d-flex gap-2 flex-wrap justify-content-center">
        <button class="btn btn-futuristic btn-sm px-4 filter-btn" data-filter="all">Tumu</button>
        <button class="btn btn-outline-futuristic btn-sm px-4 filter-btn" data-filter="istanbul">Istanbul</button>
        <button class="btn btn-outline-futuristic btn-sm px-4 filter-btn" data-filter="ankara">Ankara</button>
        <button class="btn btn-outline-futuristic btn-sm px-4 filter-btn" data-filter="izmir">Izmir</button>
        <button class="btn btn-outline-futuristic btn-sm px-4 filter-btn" data-filter="antalya">Antalya</button>
    </div>
</div>

<div class="row g-4" id="projectGrid">
@foreach (var p in projects)
{
    <div class="col-md-6 col-lg-4 project-item" data-city="@p.CityTag">
        <a href="/Projects/Detail/@p.Slug" class="text-decoration-none">
            <div class="futuristic-card h-100 overflow-hidden project-card">
                <div class="position-relative overflow-hidden" style="height:220px;">
                    <img src="@p.Img" class="w-100 h-100 project-img" style="object-fit:cover;"
                         alt="@p.Name" onerror="this.src='https://placehold.co/600x220/1a1f2e/00d4ff?text=Proje'">
                    <div class="position-absolute top-0 start-0 m-3">
                        <span class="badge px-3 py-2" style="background:linear-gradient(135deg,#00d4ff,#a855f7);border-radius:20px;">
                            <i class="bi bi-geo-alt me-1"></i>@p.City
                        </span>
                    </div>
                    <div class="position-absolute bottom-0 start-0 end-0 p-3" style="background:linear-gradient(transparent,rgba(10,14,23,0.95));">
                        <div class="text-white fw-bold fs-5" style="font-family:'Outfit',sans-serif;">@p.Name</div>
                    </div>
                </div>
                <div class="p-3">
                    <div class="d-flex gap-3 text-muted small mb-2">
                        <span><i class="bi bi-buildings me-1"></i>@p.Units Konut</span>
                        <span><i class="bi bi-calendar me-1"></i>@p.Delivery</span>
                    </div>
                    <div class="d-flex justify-content-between align-items-center">
                        <div class="text-gradient fw-bold">&#8378;@p.MinPrice'den baslayan</div>
                        <span class="badge px-2" style="background:rgba(0,212,255,0.15);color:#00d4ff;">@p.Status</span>
                    </div>
                </div>
            </div>
        </a>
    </div>
}
</div>

<div class="glass-panel p-5 text-center mt-5">
    <h5 class="fw-bold mb-2" style="font-family:'Outfit',sans-serif;">Projenizi Listeleyin</h5>
    <p class="text-muted mb-4">Insaat firmaniza ait projeleri portforde ucretsiz tanitin.</p>
    <a href="mailto:projeler@emlakportali.com" class="btn btn-futuristic px-5 py-2">
        <i class="bi bi-envelope me-2"></i>Proje Basvurusu
    </a>
</div>

@@section Scripts {
    <script>
        document.querySelectorAll('.project-card').forEach(function(card) {
            var img = card.querySelector('.project-img');
            card.addEventListener('mouseenter', function() { if(img) img.style.transform = 'scale(1.08)'; });
            card.addEventListener('mouseleave', function() { if(img) img.style.transform = 'scale(1)'; });
        });
        document.querySelectorAll('.filter-btn').forEach(function(btn) {
            btn.addEventListener('click', function() {
                document.querySelectorAll('.filter-btn').forEach(function(b) {
                    b.className = 'btn btn-outline-futuristic btn-sm px-4 filter-btn';
                });
                this.className = 'btn btn-futuristic btn-sm px-4 filter-btn';
                var filter = this.getAttribute('data-filter');
                document.querySelectorAll('.project-item').forEach(function(item) {
                    item.style.display = (filter === 'all' || item.getAttribute('data-city') === filter) ? '' : 'none';
                });
            });
        });
    </script>
}