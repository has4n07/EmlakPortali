@{
    ViewData["Title"] = "Projeler - Emlak Portali";
    var projectsList = ViewBag.ProjectsList as IEnumerable<dynamic>;
}

<div class="text-center mb-5" style="padding-top:20px;">
    <h1 class="fw-bold mb-2" style="font-family:'Outfit',sans-serif; font-size:2.5rem;">
        Seçkin <span class="text-gradient">Konut Projeleri</span>
    </h1>
    <p class="text-muted fs-5">Türkiye'nin en prestijli gayrimenkul projelerini keşfedin</p>
</div>

<div class="glass-panel p-3 mb-5">
    <div class="d-flex gap-2 flex-wrap justify-content-center">
        <button class="btn btn-futuristic btn-sm px-4 filter-btn" data-filter="all">Tümü</button>
        <button class="btn btn-outline-futuristic btn-sm px-4 filter-btn" data-filter="istanbul">İstanbul</button>
        <button class="btn btn-outline-futuristic btn-sm px-4 filter-btn" data-filter="ankara">Ankara</button>
        <button class="btn btn-outline-futuristic btn-sm px-4 filter-btn" data-filter="izmir">İzmir</button>
        <button class="btn btn-outline-futuristic btn-sm px-4 filter-btn" data-filter="antalya">Antalya</button>
    </div>
</div>

@if (projectsList != null && projectsList.Any())
{
    <div class="row g-4" id="projectGrid">
    @foreach (var p in projectsList)
    {
        var pName = ""; var pCity = ""; var pSlug = ""; var pUnits = 0; var pDelivery = ""; var pPrice = 0m; var pStatus = ""; var pImg = ""; var pCityTag = "";
        try {
            pName = p.name ?? p.Name;
            pCity = p.city ?? p.City;
            pSlug = p.slug ?? p.Slug;
            pUnits = p.totalUnits ?? p.TotalUnits ?? 0;
            pDelivery = p.deliveryDate ?? p.DeliveryDate ?? "";
            pPrice = p.minPrice ?? p.MinPrice ?? 0m;
            pStatus = p.status ?? p.Status;
            pImg = p.imageUrl ?? p.ImageUrl;
            pCityTag = p.cityTag ?? p.CityTag ?? pCity?.ToLower();
        } catch {}

        <div class="col-md-6 col-lg-4 project-item" data-city="@pCityTag">
            <a href="/Projects/Detail/@pSlug" class="text-decoration-none">
                <div class="futuristic-card h-100 overflow-hidden project-card">
                    <div class="position-relative overflow-hidden" style="height:220px;">
                        <img src="@pImg" class="w-100 h-100 project-img" style="object-fit:cover;"
                             alt="@pName" onerror="this.src='https://placehold.co/600x220/1a1f2e/00d4ff?text=Proje'">
                        <div class="position-absolute top-0 start-0 m-3">
                            <span class="badge px-3 py-2" style="background:linear-gradient(135deg,#00d4ff,#a855f7);border-radius:20px;">
                                <i class="bi bi-geo-alt me-1"></i>@pCity
                            </span>
                        </div>
                        <div class="position-absolute bottom-0 start-0 end-0 p-3" style="background:linear-gradient(transparent,rgba(10,14,23,0.95));">
                            <div class="fw-bold fs-5" style="color: #fff; font-family:'Outfit',sans-serif;">@pName</div>
                        </div>
                    </div>
                    <div class="p-3">
                        <div class="d-flex gap-3 text-muted small mb-2">
                            <span><i class="bi bi-buildings me-1"></i>@pUnits Konut</span>
                            <span><i class="bi bi-calendar me-1"></i>@pDelivery</span>
                        </div>
                        <div class="d-flex justify-content-between align-items-center">
                            <div class="text-gradient fw-bold">₺@pPrice.ToString("N0")'den başlayan</div>
                            <span class="badge px-2" style="background:rgba(0,212,255,0.15);color:#00d4ff;">@pStatus</span>
                        </div>
                    </div>
                </div>
            </a>
        </div>
    }
    </div>
}
else
{
    <div class="glass-panel p-5 text-center">
        <i class="bi bi-buildings fs-1 text-muted mb-3 d-block"></i>
        <h5 class="text-white">Henüz proje bulunmuyor.</h5>
        <p class="text-muted">Lütfen daha sonra tekrar kontrol edin.</p>
    </div>
}

<div class="glass-panel p-5 text-center mt-5">
    <h5 class="fw-bold mb-2" style="font-family:'Outfit',sans-serif;">Projenizi Listeleyin</h5>
    <p class="text-muted mb-4">İnşaat firmanıza ait projeleri portföyde ücretsiz tanıtın.</p>
    <a href="mailto:projeler@emlakportali.com" class="btn btn-futuristic px-5 py-2">
        <i class="bi bi-envelope me-2"></i>Proje Başvurusu
    </a>
</div>

@section Scripts {
    <script>
        document.querySelectorAll('.project-card').forEach(function(card) {
            var img = card.querySelector('.project-img');
            card.addEventListener('mouseenter', function() { if(img) img.style.transform = 'scale(1.08)'; });
            card.addEventListener('mouseleave', function() { if(img) img.style.transform = 'scale(1)'; });
        });
        document.querySelectorAll('.filter-btn').forEach(function(btn) {
            btn.addEventListener('click', function() {
                document.querySelectorAll('.filter-btn').forEach(function(b) {
                    b.className = 'btn btn-outline-futuristic btn-sm px-4 filter-btn';
                });
                this.className = 'btn btn-futuristic btn-sm px-4 filter-btn';
                var filter = this.getAttribute('data-filter');
                document.querySelectorAll('.project-item').forEach(function(item) {
                    item.style.display = (filter === 'all' || item.getAttribute('data-city') === filter) ? '' : 'none';
                });
            });
        });
    </script>
}