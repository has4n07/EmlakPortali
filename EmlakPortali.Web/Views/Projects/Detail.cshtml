@{
    ViewData["Title"] = "Proje Detay - Emlak Portali";
    var projectElement = ViewBag.Project as System.Text.Json.JsonElement?;
    var found = projectElement.HasValue && projectElement.Value.ValueKind != System.Text.Json.JsonValueKind.Undefined;
}

@if (!found)
{
    <div class="text-center py-5">
        <div style="font-size:4rem;">??</div>
        <h4 class="mt-3">Proje bulunamadý</h4>
        <a href="/Projects" class="btn btn-outline-futuristic mt-3">Tüm Projelere Dön</a>
    </div>
}
else
{
    var name = projectElement.Value.GetProperty("name").GetString();
    var slug = projectElement.Value.GetProperty("slug").GetString();
    var city = projectElement.Value.GetProperty("city").GetString();
    var district = projectElement.Value.GetProperty("district").GetString();
    var desc = projectElement.Value.GetProperty("description").GetString();
    var img = projectElement.Value.GetProperty("imageUrl").GetString();
    var totalUnits = projectElement.Value.GetProperty("totalUnits").GetInt32();
    var deliveryDate = projectElement.Value.GetProperty("deliveryDate").GetString();
    var minPrice = projectElement.Value.GetProperty("minPrice").GetDecimal();
    var status = projectElement.Value.GetProperty("status").GetString();
    var roomTypes = projectElement.Value.GetProperty("roomTypes").GetString();

    <div class="animate-fade-in-up">
        <!-- Breadcrumb -->
        <nav aria-label="breadcrumb" class="mb-4">
            <ol class="breadcrumb">
                <li class="breadcrumb-item"><a href="/" class="text-gradient text-decoration-none">Ana Sayfa</a></li>
                <li class="breadcrumb-item"><a href="/Projects" class="text-gradient text-decoration-none">Projeler</a></li>
                <li class="breadcrumb-item active text-muted">@name</li>
            </ol>
        </nav>

        <div class="row g-4">
            <!-- Sol: Görsel + Bilgiler -->
            <div class="col-lg-8">
                <div class="futuristic-card overflow-hidden mb-4">
                    <img src="@img" class="w-100" style="height:420px;object-fit:cover;"
                         alt="@name" onerror="this.src='https://placehold.co/900x420/1a1f2e/00d4ff?text=Proje'">
                </div>

                <div class="glass-panel p-4 mb-4">
                    <h5 class="fw-bold mb-3" style="font-family:'Outfit',sans-serif;">Proje Hakkýnda</h5>
                    <p class="text-muted lh-lg">@Html.Raw(desc)</p>
                </div>

                <div class="glass-panel p-4">
                    <h5 class="fw-bold mb-3" style="font-family:'Outfit',sans-serif;">Daire Tipleri</h5>
                    <div class="d-flex gap-2 flex-wrap">
                        @if (!string.IsNullOrWhiteSpace(roomTypes))
                        {
                            foreach (var room in roomTypes.Split(','))
                            {
                                <span class="badge px-3 py-2" style="background:rgba(0,212,255,0.1);color:var(--accent-cyan);border:1px solid rgba(0,212,255,0.3);border-radius:20px;">
                                    @room.Trim()
                                </span>
                            }
                        }
                    </div>
                </div>
            </div>

            <!-- Sađ: Özet Kart -->
            <div class="col-lg-4">
                <div class="futuristic-card p-4 mb-4 position-sticky" style="top:90px;">
                    <h4 class="fw-bold mb-1" style="font-family:'Outfit',sans-serif;">@name</h4>
                    <div class="text-muted mb-3"><i class="bi bi-geo-alt me-1"></i>@city@(string.IsNullOrWhiteSpace(district) ? "" : " / " + district)</div>

                    <div class="mb-1 text-muted small">Baţlangýç Fiyatý</div>
                    <div class="text-gradient fw-bold mb-4" style="font-size:1.8rem;">@minPrice.ToString("N0")'den baţlayan</div>

                    <div class="row g-3 mb-4">
                        <div class="col-6">
                            <div class="glass-panel p-3 text-center">
                                <div class="fw-bold text-gradient fs-4">@totalUnits</div>
                                <div class="text-muted small">Toplam Konut</div>
                            </div>
                        </div>
                        <div class="col-6">
                            <div class="glass-panel p-3 text-center">
                                <div class="fw-bold text-gradient small">@deliveryDate</div>
                                <div class="text-muted small">Teslim Tarihi</div>
                            </div>
                        </div>
                    </div>

                    <div class="mb-4">
                        @{
                            var badgeClass = status == "Satýţta" 
                                ? "bg-success bg-opacity-25 text-success" 
                                : "";
                            var badgeStyle = status == "Ön Satýţ" 
                                ? "background:rgba(0,212,255,0.15);color:var(--accent-cyan);" : "";
                        }
                        <span class="badge px-3 py-2 @badgeClass" style="@badgeStyle;border-radius:20px;">
                            @status
                        </span>
                    </div>

                    <a href="mailto:projeler@emlakportali.com?subject=@name Bilgi Talebi" 
                       class="btn btn-futuristic w-100 mb-2">
                        <i class="bi bi-envelope me-2"></i>Bilgi Talep Et
                    </a>
                    <a href="/Projects" class="btn btn-outline-futuristic w-100">
                        <i class="bi bi-arrow-left me-2"></i>Tüm Projeler
                    </a>
                </div>
            </div>
        </div>
    </div>
}
