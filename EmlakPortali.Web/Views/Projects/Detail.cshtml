@{
    ViewData["Title"] = "Proje Detay - Emlak Portali";
    var projectElement = ViewBag.Project as System.Text.Json.JsonElement?;
    var found = projectElement.HasValue && projectElement.Value.ValueKind != System.Text.Json.JsonValueKind.Undefined;
}

@if (!found)
{
    <div class="text-center py-5">
        <div style="font-size:4rem;">🏗️</div>
        <h4 class="mt-3">Proje bulunamadı</h4>
        <a href="/Projects" class="btn btn-outline-futuristic mt-3">Tüm Projelere Dön</a>
    </div>
}
else
{
    var name = projectElement.Value.TryGetProperty("name", out var n) ? n.GetString() : (projectElement.Value.TryGetProperty("Name", out var N) ? N.GetString() : "İsimsiz Proje");
    var city = projectElement.Value.TryGetProperty("city", out var c) ? c.GetString() : (projectElement.Value.TryGetProperty("City", out var C) ? C.GetString() : "");
    var district = projectElement.Value.TryGetProperty("district", out var d) ? d.GetString() : (projectElement.Value.TryGetProperty("District", out var D) ? D.GetString() : "");
    var desc = projectElement.Value.TryGetProperty("description", out var ds) ? ds.GetString() : (projectElement.Value.TryGetProperty("Description", out var DS) ? DS.GetString() : "");
    var img = projectElement.Value.TryGetProperty("imageUrl", out var i) ? i.GetString() : (projectElement.Value.TryGetProperty("ImageUrl", out var I) ? I.GetString() : "");
    
    int totalUnits = 0;
    if (projectElement.Value.TryGetProperty("totalUnits", out var tu)) totalUnits = tu.GetInt32();
    else if (projectElement.Value.TryGetProperty("TotalUnits", out var TU)) totalUnits = TU.GetInt32();

    var deliveryDate = projectElement.Value.TryGetProperty("deliveryDate", out var dd) ? dd.GetString() : (projectElement.Value.TryGetProperty("DeliveryDate", out var DD) ? DD.GetString() : "Belirtilmedi");
    
    decimal minPrice = 0;
    if (projectElement.Value.TryGetProperty("minPrice", out var mp)) minPrice = mp.GetDecimal();
    else if (projectElement.Value.TryGetProperty("MinPrice", out var MP)) minPrice = MP.GetDecimal();

    var status = projectElement.Value.TryGetProperty("status", out var s) ? s.GetString() : (projectElement.Value.TryGetProperty("Status", out var S) ? S.GetString() : "Bilinmiyor");
    var roomTypes = projectElement.Value.TryGetProperty("roomTypes", out var rt) ? rt.GetString() : (projectElement.Value.TryGetProperty("RoomTypes", out var RT) ? RT.GetString() : "");

    <div class="animate-fade-in-up">
        <!-- Breadcrumb -->
        <nav aria-label="breadcrumb" class="mb-5">
            <ol class="breadcrumb">
                <li class="breadcrumb-item"><a href="/" class="text-gradient text-decoration-none">Ana Sayfa</a></li>
                <li class="breadcrumb-item"><a href="/Projects" class="text-gradient text-decoration-none">Projeler</a></li>
                <li class="breadcrumb-item active text-muted">@name</li>
            </ol>
        </nav>

        <div class="row g-4">
            <!-- Sol: Görsel + Bilgiler -->
            <div class="col-lg-8">
                <div class="futuristic-card overflow-hidden mb-4 border-0 shadow-lg">
                    <img src="@img" class="w-100" style="height:480px;object-fit:cover;"
                         alt="@name" onerror="this.src='https://placehold.co/900x480/1a1f2e/00d4ff?text=Proje'">
                </div>

                <div class="glass-panel p-4 p-lg-5 mb-4 border-0 shadow-sm">
                    <h4 class="fw-bold mb-4 text-gradient" style="font-family:'Outfit',sans-serif;">Proje Hakkında</h4>
                    <div class="text-muted lh-lg fs-5" style="font-weight:300;">
                        @Html.Raw(desc)
                    </div>
                </div>

                <div class="glass-panel p-4 p-lg-5 border-0 shadow-sm">
                    <h5 class="fw-bold mb-4" style="font-family:'Outfit',sans-serif;">Daire Tipleri & Özellikler</h5>
                    <div class="d-flex gap-3 flex-wrap">
                        @if (!string.IsNullOrWhiteSpace(roomTypes))
                        {
                            foreach (var room in roomTypes.Split(','))
                            {
                                <div class="px-4 py-3 text-center" style="background:rgba(0,212,255,0.05); border:1px solid rgba(0,212,255,0.2); border-radius:16px; min-width:100px;">
                                    <div class="fw-bold text-gradient" style="font-size:1.2rem;">@room.Trim()</div>
                                    <div class="text-muted small">Daire Tipi</div>
                                </div>
                            }
                        }
                    </div>
                </div>
            </div>

            <!-- Sağ: Özet Kart -->
            <div class="col-lg-4">
                <div class="futuristic-card p-4 p-lg-5 mb-4 position-sticky shadow-lg" style="top:100px; border:1px solid rgba(255,255,255,0.1);">
                    <div class="mb-2">
                        @{
                            var badgeClass = status == "Satışta" 
                                ? "bg-success bg-opacity-25 text-success" 
                                : "";
                            var badgeStyle = status == "Ön Satış" 
                                ? "background:rgba(0,212,255,0.15);color:var(--accent-cyan);" : "";
                        }
                        <span class="badge px-3 py-2 @badgeClass" style="@badgeStyle; border-radius:20px; font-weight:600;">
                            @status.ToUpper()
                        </span>
                    </div>
                    
                    <h2 class="fw-bold mb-1" style="font-family:'Outfit',sans-serif; line-height:1.2;">@name</h2>
                    <div class="text-muted mb-4 fs-5"><i class="bi bi-geo-alt me-2 text-gradient"></i>@city@(string.IsNullOrWhiteSpace(district) ? "" : " / " + district)</div>

                    <div class="mb-1 text-muted small fw-bold text-uppercase tracking-wider">Başlangıç Fiyatı</div>
                    <div class="text-gradient fw-bold mb-5" style="font-size:2.2rem;">₺@minPrice.ToString("N0")'den</div>

                    <div class="row g-3 mb-5">
                        <div class="col-6">
                            <div class="glass-panel p-3 text-center border-0 shadow-sm" style="background:rgba(255,255,255,0.03);">
                                <div class="fw-bold text-gradient fs-3">@totalUnits</div>
                                <div class="text-muted small">Toplam Konut</div>
                            </div>
                        </div>
                        <div class="col-6">
                            <div class="glass-panel p-3 text-center border-0 shadow-sm" style="background:rgba(255,255,255,0.03);">
                                <div class="fw-bold text-gradient small">@deliveryDate</div>
                                <div class="text-muted small">Teslim Tarihi</div>
                            </div>
                        </div>
                    </div>

                    <a href="mailto:projeler@emlakportali.com?subject=@name Bilgi Talebi" 
                       class="btn btn-futuristic btn-lg w-100 mb-3 py-3 shadow-futuristic">
                        <i class="bi bi-envelope-fill me-2"></i>Bilgi Talep Et
                    </a>
                    <a href="/Projects" class="btn btn-outline-futuristic w-100 py-3">
                        <i class="bi bi-arrow-left me-2"></i>Tüm Projeler
                    </a>
                </div>
            </div>
        </div>
    </div>
}
