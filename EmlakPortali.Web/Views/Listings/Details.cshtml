@model int
@{
    ViewData["Title"] = "İlan Detayı";
}

<div class="container" id="detailRoot" data-id="@Model">
    <div id="errBox" class="alert alert-danger d-none mt-3 glass-panel"></div>

    <div class="row g-4 mt-2 mb-5">
        <!-- Main Content -->
        <div class="col-lg-8">
            <div class="futuristic-card h-100">
                <div class="card-img-wrapper" style="height: 500px; position: relative;">
                    <div id="listingCarousel" class="carousel slide h-100" data-bs-ride="carousel">
                        <div class="carousel-inner h-100" id="carouselInner">
                            <div class="carousel-item active h-100">
                                <img id="coverImg" src="https://picsum.photos/900/500" class="d-block w-100 h-100" style="object-fit:cover;">
                            </div>
                        </div>
                        <button class="carousel-control-prev" type="button" data-bs-target="#listingCarousel" data-bs-slide="prev">
                            <span class="carousel-control-prev-icon" aria-hidden="true"></span>
                            <span class="visually-hidden">Önceki</span>
                        </button>
                        <button class="carousel-control-next" type="button" data-bs-target="#listingCarousel" data-bs-slide="next">
                            <span class="carousel-control-next-icon" aria-hidden="true"></span>
                            <span class="visually-hidden">Sonraki</span>
                        </button>
                    </div>
                    <div class="position-absolute bottom-0 start-0 w-100 p-4" style="background: linear-gradient(to top, var(--text-main), transparent); z-index: 10; pointer-events: none;">
                        <div class="badge bg-purple px-3 py-2 text-uppercase fw-bold shadow-sm" id="listingTypeBadge" style="background: var(--accent-purple); color: white;">
                            Satılık
                        </div>
                    </div>
                </div>
                <div class="card-body p-4 p-md-5 d-flex flex-column" style="background: var(--bg-secondary);">
                    <h2 class="fw-bolder mb-3 text-white" id="title" style="font-family: 'Outfit', sans-serif;">İlan Yükleniyor...</h2>
                    
                    <div class="d-flex align-items-center mb-4 text-muted">
                        <i class="bi bi-geo-alt fs-5 me-2 text-cyan" style="color: var(--accent-cyan);"></i>
                        <span id="location" class="fs-6">Konum Yükleniyor...</span>
                    </div>
                    
                    <h5 class="text-white mb-3" style="font-family: 'Outfit', sans-serif;">
                        <i class="bi bi-card-text text-gradient"></i> Açıklama
                    </h5>
                    <p class="text-muted" id="description" style="line-height: 1.8;"></p>
                </div>
            </div>
        </div>
        
        <!-- Sidebar / Details -->
        <div class="col-lg-4">
            <div class="glass-panel p-4 position-sticky" style="top: 100px;">
                <div class="text-center mb-4">
                    <p class="text-muted small mb-1 text-uppercase tracking-wider">Fiyat</p>
                    <div class="display-5 fw-bold text-gradient" id="priceText">- ₺</div>
                </div>
                
                <hr style="border-color: var(--glass-border);">
                
                <h5 class="text-white mb-4 mt-3" style="font-family: 'Outfit', sans-serif;">
                    <i class="bi bi-list-check text-gradient"></i> Özellikler
                </h5>
                
                <ul class="list-group list-group-flush" id="specs" style="background: transparent;">
                    <li class="list-group-item d-flex justify-content-between align-items-center" style="background: transparent; border-color: var(--glass-border); color: var(--text-main);">
                        Oda Sayısı <strong class="text-cyan" style="color: var(--accent-cyan);">...</strong>
                    </li>
                </ul>
                
                <hr style="border-color: var(--glass-border);">
                
                <button class="btn btn-futuristic w-100 py-3 mt-3 shadow-lg" type="button" id="btnFavorite">
                    <i class="bi bi-heart me-2"></i> Favorilere Ekle
                </button>
                
                <div class="row mt-2 g-2">
                    <div class="col-6">
                        <a href="#" class="btn btn-outline-futuristic w-100 py-2" id="btnCall">
                            <i class="bi bi-telephone-fill me-1"></i> Ara
                        </a>
                    </div>
                    <div class="col-6">
                        <a href="#" class="btn btn-outline-futuristic w-100 py-2" id="btnMessage">
                            <i class="bi bi-chat-dots-fill me-1"></i> Mesaj
                        </a>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Fullscreen Image Modal -->
<div class="modal fade" id="imageModal" tabindex="-1" aria-hidden="true">
  <div class="modal-dialog modal-fullscreen">
    <div class="modal-content bg-transparent border-0">
      <div class="modal-header border-0 position-absolute top-0 end-0 z-3">
        <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Close" style="filter: invert(1) grayscale(100%) brightness(200%); width: 2em; height: 2em;"></button>
      </div>
      <div class="modal-body d-flex align-items-center justify-content-center p-0" data-bs-dismiss="modal" style="background: rgba(0,0,0,0.85); cursor: zoom-out;">
        <img id="fullscreenImg" src="" class="img-fluid" style="max-height: 95vh; object-fit: contain;">
      </div>
    </div>
  </div>
</div>

<!-- Send Message Modal (Chat UI) -->
<div class="modal fade" id="contactModal" tabindex="-1">
  <div class="modal-dialog modal-dialog-centered">
    <div class="modal-content border-0 shadow-lg" style="border-radius: 1rem; overflow: hidden;">
      <div class="modal-header border-0 bg-primary text-white p-3">
        <div class="d-flex align-items-center gap-3">
            <div class="bg-white rounded-circle d-flex align-items-center justify-content-center text-primary" style="width:40px; height:40px;">
                <i class="bi bi-person-fill fs-4"></i>
            </div>
            <div>
                <h6 class="modal-title fw-bold mb-0" id="chatOwnerName">İlan Sahibi</h6>
                <div class="small opacity-75">Çevrimiçi</div>
            </div>
        </div>
        <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
      </div>
      <div class="modal-body p-4 bg-light" style="min-height: 250px; max-height:400px; overflow-y:auto;" id="chatHistory">
        <div class="text-center text-muted small mb-4">Bu mesaj ilan sahibine doğrudan iletilecektir.</div>
        
        <!-- Chat bubbles will go here -->
      </div>
      <div class="modal-footer border-0 p-3 bg-white d-flex flex-nowrap align-items-center gap-2">
        <input type="hidden" id="contactName">
        <input type="hidden" id="contactEmail">
        <input type="hidden" id="contactPhone">
        
        <input type="text" class="form-control rounded-pill px-4" id="contactMessageText" placeholder="Mesajınızı yazın..." style="background-color: #f1f3f5; border:none;">
        <button type="button" class="btn btn-primary rounded-circle d-flex align-items-center justify-content-center" id="btnSendContact" style="width: 45px; height:45px;">
            <i class="bi bi-send-fill"></i>
        </button>
      </div>
    </div>
  </div>
</div>

@section Scripts {
    <script>
        window.openFullscreen = function(url) {
            document.getElementById('fullscreenImg').src = url;
            var modal = new bootstrap.Modal(document.getElementById('imageModal'));
            modal.show();
        };

        const PublicApi = (function () {
            const baseUrl = "https://localhost:7293";
            
            function getHeaders() {
                const token = UserAuth.getToken();
                const headers = { "Content-Type": "application/json" };
                if (token) headers["Authorization"] = `Bearer ${token}`;
                return headers;
            }

            async function get(url) {
                const res = await fetch(baseUrl + url, { headers: getHeaders() });
                const text = await res.text();
                let json = null; try { json = text ? JSON.parse(text) : null; } catch { }
                if (!res.ok) throw new Error(json?.message || json?.Message || text || (res.status + " " + res.statusText));
                return json;
            }

            async function post(url, data) {
                const res = await fetch(baseUrl + url, {
                    method: "POST",
                    headers: getHeaders(),
                    body: JSON.stringify(data || {})
                });
                const text = await res.text();
                let json = null; try { json = text ? JSON.parse(text) : null; } catch { }
                if (!res.ok) throw new Error(json?.message || json?.Message || text || (res.status + " " + res.statusText));
                return json;
            }

            async function put(url, data) {
                const res = await fetch(baseUrl + url, {
                    method: "PUT",
                    headers: getHeaders(),
                    body: JSON.stringify(data || {})
                });
                const text = await res.text();
                let json = null; try { json = text ? JSON.parse(text) : null; } catch { }
                if (!res.ok) throw new Error(json?.message || json?.Message || text || (res.status + " " + res.statusText));
                return json;
            }

            async function del(url) {
                const res = await fetch(baseUrl + url, {
                    method: "DELETE",
                    headers: getHeaders()
                });
                const text = await res.text();
                let json = null; try { json = text ? JSON.parse(text) : null; } catch { }
                if (!res.ok) throw new Error(json?.message || json?.Message || text || (res.status + " " + res.statusText));
                return json;
            }

            return { get, post, put, del };
        })();

        $(function () {
            const root = $("#detailRoot");
            const id = root.data("id");
            let mePromise = null;

            function setErr(msg) {
                if (!msg) { $("#errBox").addClass("d-none").text(""); return; }
                $("#errBox").removeClass("d-none").text(msg);
            }

            async function load() {
                setErr(null);
                try {
                    const res = await PublicApi.get(`/api/listings/${id}`);
                    const d = res?.data || res?.Data;
                    if (!d) { setErr("İlan bulunamadı."); return; }

                    $("#title").text(d.title ?? d.Title);
                    $("#priceText").text(`${(d.price ?? d.Price)?.toLocaleString?.("tr-TR") ?? d.price ?? d.Price} ₺`);
                    $("#location").text(`${d.cityName ?? d.CityName ?? ""} ${d.districtName ? " / " + (d.districtName ?? d.DistrictName) : ""}`);
                    $("#description").text(d.description ?? d.Description ?? "");

                    const img = imgUrl(d.coverImageUrl ?? d.CoverImageUrl);
                    const images = d.images ?? d.Images;
                    if (images && images.length > 0) {
                        const items = images.map((im, idx) => `
                            <div class="carousel-item ${idx === 0 ? 'active' : ''} h-100">
                                <img src="${im.url ?? im.Url}" class="d-block w-100 h-100" loading="${idx === 0 ? "eager" : "lazy"}" decoding="async" style="object-fit:cover; cursor: zoom-in;" onclick="openFullscreen('${im.url ?? im.Url}')">
                            </div>
                        `).join("");
                        $("#carouselInner").html(items);
                    } else if (img) {
                        $("#coverImg").attr("src", img).attr("loading", "eager").attr("decoding", "async").css("cursor", "zoom-in").on("click", () => openFullscreen(img));
                    }

                    const specs = [];
                    const add = (label, value) => { 
                        if (value != null && value !== "") {
                            specs.push(`<li class="list-group-item d-flex justify-content-between align-items-center" style="background: transparent; border-color: var(--glass-border); color: var(--text-main);">${label} <strong style="color: var(--accent-cyan);">${value}</strong></li>`); 
                        }
                    };
                    
                    add("Oda Sayısı", d.roomCount ?? d.RoomCount);
                    add("Banyo", d.bathCount ?? d.BathCount);
                    add("Net m²", d.areaNetM2 ?? d.AreaNetM2);
                    add("Brüt m²", d.areaGrossM2 ?? d.AreaGrossM2);
                    add("Bulunduğu Kat", d.floor ?? d.Floor);
                    add("Toplam Kat", d.totalFloors ?? d.TotalFloors);
                    $("#specs").html(specs.join(""));

                    const lt = d.listingType ?? d.ListingType;
                    const isRent = lt === 2;
                    $("#listingTypeBadge").text(isRent ? "Kiralık" : "Satılık");
                    if (isRent) {
                        $("#listingTypeBadge").css("background", "var(--accent-pink)");
                    }

                    const phone = d.ownerPhone ?? d.OwnerPhone ?? "";
                    if(phone) {
                        $("#btnCall").on("click", function(e) {
                            e.preventDefault();
                            $(this).html(`<i class="bi bi-telephone-fill me-1"></i> ${phone}`);
                            $(this).removeClass("btn-outline-futuristic").addClass("btn-futuristic");
                        });
                    } else {
                        $("#btnCall").on("click", (e) => { e.preventDefault(); AppNotify.warning("Telefon numarası gizli."); });
                    }

                    $("#btnMessage").on("click", async (e) => { 
                        e.preventDefault(); 
                        
                        const token = UserAuth.getToken();
                        if (!token) {
                            AppNotify.warning("Mesaj göndermek için giriş yapmalısınız.");
                            window.location.href = "/Account/Login";
                            return;
                        }

                        // Fetch sender profile once and reuse.
                        if (!mePromise) {
                            mePromise = fetch("https://localhost:7293/api/auth/me", {
                                headers: { "Authorization": `Bearer ${token}` }
                            })
                                .then(r => r.ok ? r.json() : null)
                                .catch(() => null);
                        }
                        try {
                            const me = await mePromise;
                            const u = me?.data || me?.Data;
                            if (u) {
                                $("#contactName").val(u.fullName || u.FullName || u.email || u.Email);
                                $("#contactEmail").val(u.email || u.Email);
                                $("#contactPhone").val(u.phone || u.PhoneNumber || "0000000000");
                            }
                        } catch {}

                        $("#chatOwnerName").text(d.ownerName ?? d.OwnerName ?? "İlan Sahibi");
                        $("#contactMessageText").val("");
                        
                        // Clear old bubbles
                        $("#chatHistory").html('<div class="text-center text-muted small mb-4">Bu mesaj ilan sahibine doğrudan iletilecektir.</div>');

                        new bootstrap.Modal(document.getElementById('contactModal')).show();
                        
                        // Focus on text box
                        setTimeout(() => $("#contactMessageText").focus(), 500);
                    });

                    $("#btnSendContact").off("click").on("click", async function () {
                        const btn = $(this);
                        const msgText = $("#contactMessageText").val().trim();
                        if (!msgText) return;

                        btn.prop("disabled", true).html('<span class="spinner-border spinner-border-sm"></span>');

                        try {
                            const payload = {
                                listingId: id,
                                senderName: $("#contactName").val() || "Kullanıcı",
                                senderEmail: $("#contactEmail").val() || "no-reply@emlakportali.com",
                                senderPhone: $("#contactPhone").val() || "000",
                                message: msgText
                            };

                            const res = await PublicApi.post("/api/contactmessages", payload);
                            
                            // Append bubble
                            const bubble = `
                                <div class="d-flex justify-content-end mb-3">
                                    <div class="bg-primary text-white rounded-3 py-2 px-3 shadow-sm" style="max-width: 80%;">
                                        <div style="word-break: break-word;">${msgText}</div>
                                        <div class="text-end small opacity-75 mt-1" style="font-size:0.7rem;">Şimdi</div>
                                    </div>
                                </div>
                            `;
                            $("#chatHistory").append(bubble);
                            
                            // Scroll to bottom
                            const chatHistory = document.getElementById("chatHistory");
                            chatHistory.scrollTop = chatHistory.scrollHeight;

                            $("#contactMessageText").val("");
                        } catch (err) {
                            AppNotify.error("Gönderilemedi: " + (err.message ?? String(err)));
                        } finally {
                            btn.prop("disabled", false).html('<i class="bi bi-send-fill"></i>');
                            $("#contactMessageText").focus();
                        }
                    });

                } catch (e) {
                    setErr(e?.message ?? String(e));
                }
            }

            $("#btnFavorite").on("click", async function () {
                const token = UserAuth.getToken();
                if (!token) {
                    AppNotify.warning("Favorilere eklemek için lütfen giriş yapın.");
                    window.location.href = "/Account/Login";
                    return;
                }

                const btn = $(this);
                const isFavorited = btn.hasClass("btn-outline-futuristic"); // If outline, it means it is CURRENTLY favorited
                
                try {
                    btn.prop("disabled", true);
                    if (isFavorited) {
                        await PublicApi.del(`/api/favorites/${id}`);
                        btn.removeClass("btn-outline-futuristic").addClass("btn-futuristic");
                        btn.html('<i class="bi bi-heart me-2"></i> Favorilere Ekle');
                        btn.css("border-color", "");
                        btn.css("color", "");
                    } else {
                        await PublicApi.post(`/api/favorites/${id}`, {});
                        btn.removeClass("btn-futuristic").addClass("btn-outline-futuristic");
                        btn.html('<i class="bi bi-heart-fill me-2" style="color: var(--accent-pink);"></i> Favorilerde');
                        btn.css("border-color", "var(--accent-pink)");
                        btn.css("color", "var(--accent-pink)");
                    }
                } catch (e) {
                    AppNotify.error("İşlem başarısız: " + (e?.message || e));
                } finally {
                    btn.prop("disabled", false);
                }
            });

            load();
        });
    </script>
}