<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - EmlakPortali</title>
    
    <!-- Google Fonts: Outfit and Inter -->
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600&family=Outfit:wght@400;600;800&display=swap" rel="stylesheet">
    
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/EmlakPortali.Web.styles.css" asp-append-version="true" />
</head>
<body class="d-flex flex-column min-vh-100">
    <header>
        <nav class="navbar navbar-expand-sm navbar-toggleable-sm glass-nav fixed-top mb-3">
            <div class="container-fluid px-4">
                <a class="navbar-brand" asp-area="" asp-controller="Home" asp-action="Index">Emlak<span class="text-gradient">Portali</span></a>
                <button class="navbar-toggler btn-outline-futuristic" type="button" data-bs-toggle="collapse" data-bs-target=".navbar-collapse" aria-controls="navbarSupportedContent"
                        aria-expanded="false" aria-label="Toggle navigation">
                    <i class="bi bi-list"></i>
                </button>
                <div class="navbar-collapse collapse d-sm-inline-flex justify-content-between">
                    <ul class="navbar-nav flex-grow-1" id="mainNavLinks">
                        <li class="nav-item">
                            <a class="nav-link" asp-area="" asp-controller="Home" asp-action="Index">Ana Sayfa</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" asp-area="" asp-controller="Listings" asp-action="Index">Tüm İlanlar</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" href="/Listings?listingType=1">Satılık</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" href="/Listings?listingType=2">Kiralık</a>
                        </li>
                        <li class="nav-item dropdown">
                            <a class="nav-link dropdown-toggle" href="#" role="button" data-bs-toggle="dropdown" aria-expanded="false">Projeler</a>
                            <ul class="dropdown-menu shadow border-0 mt-2">
                                <li><a class="dropdown-item" href="/Projects"><i class="bi bi-buildings me-2"></i>Tüm Projeler</a></li>
                                <li><hr class="dropdown-divider"></li>
                                <li><a class="dropdown-item" href="/Projects?city=istanbul"><i class="bi bi-geo-alt me-2"></i>İstanbul</a></li>
                                <li><a class="dropdown-item" href="/Projects?city=ankara"><i class="bi bi-geo-alt me-2"></i>Ankara</a></li>
                                <li><a class="dropdown-item" href="/Projects?city=izmir"><i class="bi bi-geo-alt me-2"></i>İzmir</a></li>
                                <li><a class="dropdown-item" href="/Projects?city=antalya"><i class="bi bi-geo-alt me-2"></i>Antalya</a></li>
                            </ul>
                        </li>
                    </ul>
                    <ul class="navbar-nav align-items-center">
                        <li class="nav-item me-3">
                            <a class="btn btn-sm btn-futuristic shadow-sm" href="#" onclick="checkLoginAndRedirect('/Listings/Create')">
                                <i class="bi bi-plus-circle"></i> İlan Ekle
                            </a>
                        </li>
                        <li class="nav-item" id="navLoginLink">
                            <a class="btn btn-outline-futuristic btn-sm" href="/Account/Login">Giriş Yap</a>
                        </li>
                        <li class="nav-item dropdown" id="navProfileLink" style="display:none;">
                            <a class="nav-link dropdown-toggle d-flex align-items-center gap-2" href="#" id="navbarDropdown" role="button" data-bs-toggle="dropdown" aria-expanded="false">
                                <img src="/images/default-avatar.png" id="navAvatar" alt="Profile" class="rounded-circle border" style="width: 32px; height: 32px; object-fit: cover;" onerror="this.onerror=null;this.src='/images/default-avatar.png';">
                            </a>
                            <ul class="dropdown-menu dropdown-menu-end shadow border-0 mt-2" aria-labelledby="navbarDropdown">
                                <li><a class="dropdown-item fw-bold text-gradient" href="/Account/Me"><i class="bi bi-person me-2"></i> Profilim</a></li>
                                <li><a class="dropdown-item" href="/Account/Favorites"><i class="bi bi-heart me-2 text-danger"></i> Favorilerim</a></li>
                                <li><a class="dropdown-item" href="/Account/Messages"><i class="bi bi-chat-dots me-2 text-primary"></i> Mesajlarım</a></li>
                                <li id="panelLi" style="display:none;"><a class="dropdown-item" href="/Admin/Dashboard" id="panelLinkText"><i class="bi bi-grid-1x2 me-2"></i> Yönetim Paneli</a></li>
                                <li><hr class="dropdown-divider"></li>
                                <li><a class="dropdown-item text-danger" href="#" onclick="logout()"><i class="bi bi-box-arrow-right me-2"></i> Çıkış Yap</a></li>
                            </ul>
                        </li>
                        <li class="nav-item ms-2 d-flex align-items-center">
                            <button id="themeToggleBtn" class="btn btn-outline-secondary btn-sm rounded-circle" style="width: 36px; height: 36px; padding: 0; line-height: 32px; color: var(--nav-text); border-color: var(--glass-border);">
                                <i class="bi bi-moon-stars" id="themeToggleIcon"></i>
                            </button>
                        </li>
                    </ul>
                </div>
            </div>
        </nav>
    </header>
    
    <!-- Add padding top to account for fixed navbar -->
    <div class="container flex-grow-1" style="padding-top: 100px;">
        <main role="main" class="pb-5">
            @RenderBody()
        </main>
    </div>

    <footer class="footer pt-5 pb-4 mt-auto" style="background: var(--footer-bg); border-top: 1px solid var(--glass-border); position: relative; height: auto !important; line-height: normal !important;">
        <div class="container">
            <div class="row g-4 mb-4">
                <div class="col-lg-4">
                    <h5 class="fw-bold mb-3 text-white">Emlak<span class="text-gradient">Portali</span></h5>
                    <p class="text-muted small mb-3" style="white-space: normal !important; line-height: 1.5 !important;">Türkiye'nin en modern ve kullanıcı dostu gayrimenkul platformu. Hayalindeki evi veya karlı yatırım fırsatını hemen keşfet.</p>
                    <div class="d-flex gap-2">
                        <a href="#" class="btn btn-outline-futuristic btn-sm rounded-circle" style="width: 36px; height: 36px; padding: 0; line-height: 32px;"><i class="bi bi-facebook"></i></a>
                        <a href="#" class="btn btn-outline-futuristic btn-sm rounded-circle" style="width: 36px; height: 36px; padding: 0; line-height: 32px;"><i class="bi bi-twitter-x"></i></a>
                        <a href="#" class="btn btn-outline-futuristic btn-sm rounded-circle" style="width: 36px; height: 36px; padding: 0; line-height: 32px;"><i class="bi bi-instagram"></i></a>
                        <a href="#" class="btn btn-outline-futuristic btn-sm rounded-circle" style="width: 36px; height: 36px; padding: 0; line-height: 32px;"><i class="bi bi-linkedin"></i></a>
                    </div>
                </div>
                <div class="col-lg-2 col-md-4">
                    <h6 class="text-white mb-3">Hızlı Linkler</h6>
                    <ul class="list-unstyled small text-muted">
                        <li class="mb-2"><a href="/" class="text-decoration-none text-muted hover-cyan">Ana Sayfa</a></li>
                        <li class="mb-2"><a href="/Listings" class="text-decoration-none text-muted hover-cyan">Tüm İlanlar</a></li>
                        <li class="mb-2"><a href="/Projects" class="text-decoration-none text-muted hover-cyan">Projeler</a></li>
                    </ul>
                </div>
                <div class="col-lg-2 col-md-4">
                    <h6 class="text-white mb-3">Kategoriler</h6>
                    <ul class="list-unstyled small text-muted">
                        <li class="mb-2"><a href="/Listings?listingType=1" class="text-decoration-none text-muted hover-cyan">Satılık Evler</a></li>
                        <li class="mb-2"><a href="/Listings?listingType=2" class="text-decoration-none text-muted hover-cyan">Kiralık Evler</a></li>
                        <li class="mb-2"><a href="/Listings?categoryId=2" class="text-decoration-none text-muted hover-cyan">Arsa & Arazi</a></li>
                        <li class="mb-2"><a href="/Listings?categoryId=3" class="text-decoration-none text-muted hover-cyan">İş Yeri</a></li>
                    </ul>
                </div>
                <div class="col-lg-4 col-md-4">
                    <h6 class="text-white mb-3">İletişim</h6>
                    <ul class="list-unstyled small text-muted">
                        <li class="mb-2"><i class="bi bi-geo-alt me-2 text-gradient"></i> Maslak Mah. Büyükdere Cad. No:1, Şişli, İstanbul</li>
                        <li class="mb-2"><i class="bi bi-envelope me-2 text-gradient"></i> info@emlakportali.local</li>
                        <li class="mb-2"><i class="bi bi-telephone me-2 text-gradient"></i> +90 (850) 123 45 67</li>
                    </ul>
                </div>
            </div>
            <div class="border-top pt-3 mt-3 d-flex flex-column flex-md-row justify-content-between align-items-center" style="border-color: rgba(255,255,255,0.05) !important;">
                <div class="small text-muted mb-2 mb-md-0">
                    &copy; 2026 - Emlak Portali - <span class="text-gradient fw-bold">Hasan Esmer</span>. Tüm hakları saklıdır.
                </div>
                <div class="small text-muted">
                    <a href="#" class="text-decoration-none text-muted me-3 hover-cyan">Gizlilik Politikası</a>
                    <a href="#" class="text-decoration-none text-muted hover-cyan">Kullanım Şartları</a>
                </div>
            </div>
        </div>
    </footer>
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
    
    <!-- Auth script check -->
    <script>
        function parseJwt(token) {
            try {
                return JSON.parse(atob(token.split('.')[1]));
            } catch (e) {
                return null;
            }
        }

        function logout() {
            localStorage.removeItem("token");
            window.location.href = "/";
        }

        function applyDefaultAvatarIfEmpty(imgEl, value) {
            const url = (value || "").toString().trim();
            imgEl.src = url || "/images/default-avatar.png";
        }

        function checkLoginAndRedirect(url) {
            const token = localStorage.getItem("token");
            if (!token) {
                AppNotify.warning("İlan eklemek için giriş yapmalısınız.");
                window.location.href = "/Account/Login";
            } else {
                const payload = parseJwt(token);
                const roleClaim = payload?.["http://schemas.microsoft.com/ws/2008/06/identity/claims/role"];
                const roles = Array.isArray(roleClaim) ? roleClaim : [roleClaim].filter(Boolean);
                const canCreateListing = roles.includes("Realtor") || roles.includes("Admin");
                if (!canCreateListing) {
                    window.location.href = "/Listings/RealtorRequired";
                    return;
                }
                window.location.href = url;
            }
        }

        document.addEventListener("DOMContentLoaded", async function() {
            const token = localStorage.getItem("token");
            if(token) {
                document.getElementById("navLoginLink").style.display = "none";
                document.getElementById("navProfileLink").style.display = "block";
                
                const payload = parseJwt(token);
                if (payload) {
                    const roleClaim = payload["http://schemas.microsoft.com/ws/2008/06/identity/claims/role"];
                    const roles = Array.isArray(roleClaim) ? roleClaim : [roleClaim];
                    
                    // Sync token to admin panel so they don't have to login again
                    localStorage.setItem("emlak_admin_jwt", token);
                    
                    if (roles.includes("Realtor")) {
                        document.getElementById("panelLi").style.display = "block";
                        document.getElementById("panelLinkText").innerHTML = '<i class="bi bi-grid-1x2 me-2"></i> Emlakçı Paneli';
                    } else if (roles.includes("Admin")) {
                        document.getElementById("panelLi").style.display = "block";
                        document.getElementById("panelLinkText").innerHTML = '<i class="bi bi-grid-1x2 me-2"></i> Admin Paneli';
                    }

                    // Fetch Profile Picture
                    try {
                        const res = await fetch("https://localhost:7293/api/profile/me", {
                            headers: { "Authorization": `Bearer ${token}` }
                        });
                        if (res.ok) {
                            const data = await res.json();
                            const pUrl = data?.data?.profilePictureUrl || data?.Data?.ProfilePictureUrl || "";
                            // If URL is relative, prepend API base URL
                            const fullUrl = pUrl.startsWith('http') ? pUrl : (pUrl ? 'https://localhost:7293' + pUrl : '');
                            applyDefaultAvatarIfEmpty(document.getElementById("navAvatar"), fullUrl);
                        }
                    } catch(e) {}
                }
            }
        });
    </script>
</body>
</html>
