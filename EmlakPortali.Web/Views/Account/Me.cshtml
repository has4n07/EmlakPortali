@{
    ViewData["Title"] = "Hesabım";
}

<style>
/* ── Profil Sayfası Özel Stiller ────────────────────────────────── */
.profile-sidebar { position: sticky; top: 90px; }
.profile-avatar-wrap {
    position: relative; width: 120px; height: 120px; margin: 0 auto;
    cursor: pointer;
}
.profile-avatar-wrap img {
    width: 120px; height: 120px; border-radius: 50%; object-fit: cover;
    border: 3px solid var(--accent-cyan);
    transition: filter 0.3s;
}
.profile-avatar-wrap:hover img { filter: brightness(0.7); }
.avatar-overlay {
    position: absolute; inset: 0; border-radius: 50%;
    display: flex; align-items: center; justify-content: center;
    background: rgba(0,212,255,0.25); opacity: 0;
    transition: opacity 0.3s; pointer-events: none;
    font-size: 1.8rem; color: #fff;
}
.profile-avatar-wrap:hover .avatar-overlay { opacity: 1; }

.profile-nav-item {
    display: flex; align-items: center; gap: 10px; padding: 12px 16px;
    border-radius: 12px; margin-bottom: 4px; cursor: pointer;
    color: var(--text-muted); transition: all 0.2s; border: none;
    background: transparent; width: 100%; text-align: left;
    font-size: 0.95rem;
}
.profile-nav-item:hover { background: rgba(0,212,255,0.06); color: var(--text-primary); }
.profile-nav-item.active { background: rgba(0,212,255,0.12); color: var(--accent-cyan); }
.profile-nav-item.active i { color: var(--accent-cyan); }

.profile-tab { display: none; }
.profile-tab.show { display: block; animation: fadeSlideIn 0.3s ease; }
@@keyframes fadeSlideIn {
    from { opacity:0; transform:translateY(8px); }
    to   { opacity:1; transform:translateY(0); }
}

.listing-row-card {
    background: rgba(255,255,255,0.03); border-radius: 14px;
    border: 1px solid rgba(255,255,255,0.06); padding: 14px 18px;
    margin-bottom: 10px; transition: all 0.2s;
    display: flex; align-items: center; justify-content: space-between; gap: 10px;
}
.listing-row-card:hover { background: rgba(0,212,255,0.05); border-color: rgba(0,212,255,0.2); }
</style>

<div class="container animate-fade-in-up pb-5" style="max-width:1100px;">
    <div id="errBox" class="alert alert-danger d-none mb-4"></div>

    <div class="row g-4 align-items-start">
        <!-- ════ SIDEBAR ════ -->
        <div class="col-lg-3">
            <div class="glass-panel p-4 text-center profile-sidebar">
                <!-- Avatar Yükleme -->
                <div class="profile-avatar-wrap mb-3" onclick="document.getElementById('avatarFileInput').click()" title="Fotoğraf değiştir">
                    <img id="ppPreview" src="/images/default-avatar.png" alt="Avatar"
                         onerror="this.onerror=null;this.src='/images/default-avatar.png';">
                    <div class="avatar-overlay"><i class="bi bi-camera-fill"></i></div>
                </div>
                <input type="file" id="avatarFileInput" accept=".jpg,.jpeg,.png,.webp" class="d-none">

                <div id="avatarUploadProgress" class="d-none mb-2">
                    <div class="progress" style="height:4px;border-radius:4px;">
                        <div class="progress-bar" style="width:0%;background:var(--accent-cyan);transition:width 0.3s;"></div>
                    </div>
                    <div class="text-muted small mt-1">Yükleniyor...</div>
                </div>

                <div class="fw-bold text-white mb-1" id="sidebarName" style="font-family:'Outfit',sans-serif;font-size:1.1rem;">—</div>
                <div class="text-muted small mb-1" id="sidebarEmail">—</div>
                <div id="sidebarRole" class="mb-4"></div>

                <!-- Nav -->
                <div class="text-start">
                    <button class="profile-nav-item active" onclick="showTab('tabProfile',this)">
                        <i class="bi bi-person-fill"></i> Profilim
                    </button>
                    <button class="profile-nav-item" onclick="showTab('tabMyListings',this)">
                        <i class="bi bi-house-door-fill"></i> İlanlarım
                    </button>
                    <button class="profile-nav-item" onclick="showTab('tabFavorites',this)">
                        <i class="bi bi-heart-fill"></i> Favorilerim
                    </button>
                    <button class="profile-nav-item" onclick="showTab('tabSecurity',this)">
                        <i class="bi bi-shield-lock-fill"></i> Güvenlik
                    </button>
                </div>

                <div class="mt-4 border-top border-white border-opacity-10 pt-3">
                    <button class="btn btn-sm w-100" id="btnLogout" type="button"
                            style="background:rgba(255,59,59,0.1);color:#ff6b6b;border:1px solid rgba(255,59,59,0.25);border-radius:10px;">
                        <i class="bi bi-box-arrow-right me-2"></i>Çıkış Yap
                    </button>
                </div>
            </div>
        </div>

        <!-- ════ CONTENT ════ -->
        <div class="col-lg-9">

            <!-- ── Profil Sekmesi ── -->
            <div class="profile-tab show" id="tabProfile">
                <div class="glass-panel p-4 p-lg-5">
                    <h5 class="fw-bold mb-1" style="font-family:'Outfit',sans-serif;">Profil Bilgilerim</h5>
                    <p class="text-muted small mb-4">Kişisel bilgilerinizi güncelleyin</p>

                    <div class="alert alert-success d-none" id="okProfile" style="border-radius:12px;"></div>

                    <div class="row g-3">
                        <div class="col-md-6">
                            <label class="form-label text-muted small fw-semibold text-uppercase" style="letter-spacing:.05em;">Ad Soyad</label>
                            <input class="form-control" id="fullName" placeholder="Adınız Soyadınız" style="border-radius:10px;" />
                        </div>
                        <div class="col-md-6">
                            <label class="form-label text-muted small fw-semibold text-uppercase" style="letter-spacing:.05em;">E-posta</label>
                            <input class="form-control" id="email" disabled style="border-radius:10px;opacity:.6;" />
                        </div>
                        <div class="col-md-6">
                            <label class="form-label text-muted small fw-semibold text-uppercase" style="letter-spacing:.05em;">Telefon</label>
                            <div class="input-group">
                                <span class="input-group-text" style="border-radius:10px 0 0 10px;background:rgba(255,255,255,0.04);border-color:rgba(255,255,255,0.1);color:var(--text-muted);">
                                    <i class="bi bi-telephone"></i>
                                </span>
                                <input class="form-control" id="phoneNumber" placeholder="0555 555 55 55" style="border-radius:0 10px 10px 0;" />
                            </div>
                        </div>
                        <div class="col-12 mt-2">
                            <button class="btn btn-futuristic px-5" id="btnSaveProfile" type="button">
                                <i class="bi bi-check2-circle me-2"></i>Kaydet
                            </button>
                        </div>
                    </div>
                </div>
            </div>

            <!-- ── İlanlarım Sekmesi ── -->
            <div class="profile-tab" id="tabMyListings">
                <div class="glass-panel p-4">
                    <div class="d-flex justify-content-between align-items-center mb-4">
                        <div>
                            <h5 class="fw-bold mb-0" style="font-family:'Outfit',sans-serif;">İlanlarım</h5>
                            <div class="text-muted small" id="myListingsInfo">Yükleniyor...</div>
                        </div>
                        <a href="/Listings/Create" class="btn btn-futuristic btn-sm px-3" onclick="event.preventDefault();checkLoginAndRedirect('/Listings/Create')">
                            <i class="bi bi-plus-lg me-1"></i>Yeni İlan
                        </a>
                    </div>
                    <div id="myListingsRows">
                        <div class="listing-row-card"><span class="text-muted">Yükleniyor...</span></div>
                    </div>
                </div>
            </div>

            <!-- ── Favorilerim Sekmesi ── -->
            <div class="profile-tab" id="tabFavorites">
                <div class="glass-panel p-4">
                    <h5 class="fw-bold mb-4" style="font-family:'Outfit',sans-serif;">Favorilerim</h5>
                    <div id="favRows">
                        <div class="listing-row-card"><span class="text-muted">Yükleniyor...</span></div>
                    </div>
                </div>
            </div>

            <!-- ── Güvenlik Sekmesi ── -->
            <div class="profile-tab" id="tabSecurity">
                <div class="glass-panel p-4 p-lg-5">
                    <h5 class="fw-bold mb-1" style="font-family:'Outfit',sans-serif;">Hesap Güvenliği</h5>
                    <p class="text-muted small mb-4">Güvenliğiniz için şifrenizi düzenli olarak güncelleyin</p>

                <div class="mt-3 glass-panel p-4">
                    <div class="mb-3">
                        <label class="form-label text-muted small fw-semibold text-uppercase">Mevcut Şifre</label>
                        <input class="form-control" type="password" id="currentPassword" placeholder="••••••••" style="border-radius:10px;" />
                    </div>
                    <div class="mb-3">
                        <label class="form-label text-muted small fw-semibold text-uppercase">Yeni Şifre</label>
                        <input class="form-control" type="password" id="newPassword" placeholder="••••••••" style="border-radius:10px;" />
                    </div>
                    <div class="mb-3">
                        <label class="form-label text-muted small fw-semibold text-uppercase">Yeni Şifre (Tekrar)</label>
                        <input class="form-control" type="password" id="confirmPassword" placeholder="••••••••" style="border-radius:10px;" />
                    </div>
                    <div id="pwdChangeMsg" class="alert d-none mb-3" style="border-radius:12px;"></div>
                    <button class="btn btn-futuristic px-5" id="btnChangePassword">
                        <i class="bi bi-shield-check me-2"></i>Şifreyi Güncelle
                    </button>
                </div>
                </div>
            </div>

        </div>
    </div>
</div>

@section Scripts {
<script>
    /* ── Tab kontrolü ── */
    function showTab(tabId, btn) {
        document.querySelectorAll('.profile-tab').forEach(t => t.classList.remove('show'));
        document.querySelectorAll('.profile-nav-item').forEach(b => b.classList.remove('active'));
        document.getElementById(tabId)?.classList.add('show');
        btn?.classList.add('active');
    }

    /* ── UserApi ── */
    const UserApi = (function () {
        const base = UserAuth.apiBase;
        async function request(method, url, body) {
            const token = UserAuth.getToken();
            if (!token) throw new Error("Lütfen önce giriş yapın.");
            const res = await fetch(base + url, {
                method,
                headers: { "Content-Type": "application/json", "Authorization": "Bearer " + token },
                body: body ? JSON.stringify(body) : undefined
            });
            const text = await res.text();
            let json = null; try { json = text ? JSON.parse(text) : null; } catch { }
            if (!res.ok || (!json?.status && !json?.Status)) {
                throw new Error(json?.message || json?.Message || text || (res.status + " " + res.statusText));
            }
            return json;
        }
        async function upload(url, file) {
            const token = UserAuth.getToken();
            const fd = new FormData();
            fd.append("file", file);
            const res = await fetch(base + url, {
                method: "POST",
                headers: { "Authorization": "Bearer " + token },
                body: fd
            });
            const text = await res.text();
            let json = null; try { json = text ? JSON.parse(text) : null; } catch { }
            if (!res.ok) throw new Error(json?.message || json?.Message || text || "Yükleme hatası");
            return json;
        }
        return {
            get: (u) => request("GET", u),
            put: (u, b) => request("PUT", u, b),
            post: (u, b) => request("POST", u, b),
            upload: (u, f) => upload(u, f)
        };
    })();

    $(function () {
        function setErr(msg) {
            if (!msg) { $("#errBox").addClass("d-none").text(""); return; }
            $("#errBox").removeClass("d-none").text(msg);
        }

        /* ── Profil Yükle ── */
        async function loadProfile() {
            try {
                const res = await UserApi.get("/api/profile/me");
                const u = res?.data || res?.Data || {};
                const name = u.fullName ?? u.FullName ?? "";
                const email = u.email ?? u.Email ?? "";
                const phone = u.phoneNumber ?? u.PhoneNumber ?? "";
                const pp = (u.profilePictureUrl ?? u.ProfilePictureUrl ?? "").toString().trim();
                const roles = u.roles ?? u.Roles ?? [];

                $("#fullName").val(name);
                $("#email").val(email);
                $("#phoneNumber").val(phone);
                $("#sidebarName").text(name || "Kullanıcı");
                $("#sidebarEmail").text(email);

                // Rol badge
                let roleBadge = "";
                if (roles.includes("Admin")) roleBadge = '<span class="badge px-3 py-1" style="background:linear-gradient(135deg,var(--accent-pink),var(--accent-purple));border-radius:20px;font-size:.75rem;">Admin</span>';
                else if (roles.includes("Realtor")) roleBadge = '<span class="badge px-3 py-1" style="background:linear-gradient(135deg,var(--accent-cyan),var(--accent-purple));border-radius:20px;font-size:.75rem;"><i class=\'bi bi-patch-check me-1\'></i>Emlakçı</span>';
                else roleBadge = '<span class="badge px-3 py-1" style="background:rgba(255,255,255,0.07);border-radius:20px;font-size:.75rem;">Üye</span>';
                $("#sidebarRole").html(roleBadge);

                const avatarEl = document.getElementById("ppPreview");
                _currentPpUrl = pp;
                // If URL is relative, prepend API base URL for proper loading
                const displayUrl = (pp && !pp.startsWith('http')) ? 'https://localhost:7293' + pp : (pp || '');
                if (displayUrl) { avatarEl.src = displayUrl; } else { avatarEl.src = "/images/default-avatar.png"; }
                avatarEl.onerror = function() { this.onerror=null; this.src="/images/default-avatar.png"; };
            } catch (e) {
                setErr(e?.message ?? String(e));
            }
        }

        /* ── Avatar Dosya Yükleme ── */
        $("#avatarFileInput").on("change", async function() {
            const file = this.files?.[0];
            if (!file) return;

            // Önizleme
            const objectUrl = URL.createObjectURL(file);
            $("#ppPreview").attr("src", objectUrl);

            // Progress bar göster
            const progressWrap = $("#avatarUploadProgress");
            const progressBar = progressWrap.find(".progress-bar");
            progressWrap.removeClass("d-none");
            progressBar.css("width","30%");

            try {
                progressBar.css("width","60%");
                const uploadRes = await UserApi.upload("/api/profile/upload-profile-picture", file);
                const uploadedUrl = uploadRes?.data?.url || uploadRes?.Data?.Url || uploadRes?.data?.Url || uploadRes?.url;
                if (!uploadedUrl) throw new Error("URL alınamadı.");

                progressBar.css("width","90%");

                // Profili güncelle
                await UserApi.put("/api/profile", {
                    fullName: $("#fullName").val(),
                    phoneNumber: $("#phoneNumber").val(),
                    profilePictureUrl: uploadedUrl
                });

                progressBar.css("width","100%");
                _currentPpUrl = uploadedUrl;
                $("#ppPreview").attr("src", uploadedUrl);

                // Navbar avatarını da güncelle
                const navAvatar = document.getElementById("navAvatar");
                if (navAvatar) navAvatar.src = uploadedUrl;

                AppNotify.success("Profil fotoğrafı güncellendi!");
            } catch(e) {
                setErr("Fotoğraf yüklenirken hata: " + (e?.message ?? String(e)));
                $("#ppPreview").attr("src", "/images/default-avatar.png");
            } finally {
                setTimeout(() => progressWrap.addClass("d-none"), 800);
                this.value = "";
            }
        });

        /* ── Profil Kaydet ── */
        let _currentPpUrl = "";   // mevcut avatar URL'si burada tutulur

        $("#btnSaveProfile").on("click", async function () {
            $("#okProfile").addClass("d-none").text("");
            const btn = $(this);
            btn.prop("disabled", true).html('<span class="spinner-border spinner-border-sm me-2"></span>Kaydediliyor...');
            try {
                await UserApi.put("/api/profile", {
                    fullName: $("#fullName").val(),
                    phoneNumber: $("#phoneNumber").val(),
                    profilePictureUrl: _currentPpUrl || null
                });
                $("#sidebarName").text($("#fullName").val());
                $("#okProfile").removeClass("d-none").text("✓ Profil başarıyla güncellendi.");
            } catch (e) {
                setErr(e?.message ?? String(e));
            } finally {
                btn.prop("disabled", false).html('<i class="bi bi-check2-circle me-2"></i>Kaydet');
            }
        });

        /* ── Şifre Değiştir ── */
        $("#btnChangePassword").on("click", async function () {
            const currentPwd = $("#currentPassword").val();
            const newPwd = $("#newPassword").val();
            const confirmPwd = $("#confirmPassword").val();
            const msgBox = $("#pwdChangeMsg");

            msgBox.addClass("d-none").removeClass("alert-success alert-danger").text("");

            if (!currentPwd || !newPwd) {
                msgBox.addClass("alert-danger d-block").text("Mevcut şifre ve yeni şifre zorunludur.");
                return;
            }

            if (newPwd.length < 6) {
                msgBox.addClass("alert-danger d-block").text("Yeni şifre en az 6 karakter olmalıdır.");
                return;
            }

            if (newPwd !== confirmPwd) {
                msgBox.addClass("alert-danger d-block").text("Yeni şifreler uyuşmuyor.");
                return;
            }

            const btn = $(this);
            btn.prop("disabled", true).html('<span class="spinner-border spinner-border-sm me-2"></span>Değiştiriliyor...');

            try {
                const result = await UserApi.post("/api/profile/change-password", {
                    currentPassword: currentPwd,
                    newPassword: newPwd
                });

                msgBox.addClass("alert-success d-block").text("✓ Şifreniz başarıyla değiştirildi.");
                $("#currentPassword, #newPassword, #confirmPassword").val("");
            } catch (e) {
                msgBox.addClass("alert-danger d-block").text("Hata: " + (e?.message ?? String(e)));
            } finally {
                btn.prop("disabled", false).html('<i class="bi bi-shield-check me-2"></i>Şifreyi Güncelle');
            }
        });

        /* ── İlanlarım ── */
        async function loadMyListings() {
            try {
                const qs = new URLSearchParams({ page: 1, pageSize: 100, orderBy: 1 });
                const res = await UserApi.get("/api/listings/mine?" + qs.toString());
                const data = res?.data || res?.Data;
                const items = data?.items || data?.Items || [];
                const total = data?.totalCount || data?.TotalCount || items.length;
                $("#myListingsInfo").text(`Toplam ${total} ilan`);
                if (!items.length) {
                    $("#myListingsRows").html('<div class="listing-row-card"><span class="text-muted">Henüz ilanınız yok.</span></div>');
                    return;
                }
                const html = items.map(x => {
                    const id = x.id ?? x.Id;
                    const title = x.title ?? x.Title;
                    const price = x.price ?? x.Price;
                    const rawDate = x.createdAtUtc ?? x.CreatedAtUtc ?? x.created ?? x.Created;
                    const dateStr = rawDate ? new Date(rawDate).toLocaleDateString("tr-TR") : "-";
                    return `<div class="listing-row-card">
                        <div>
                            <div class="fw-semibold text-white">${title}</div>
                            <div class="text-muted small">${dateStr}</div>
                        </div>
                        <div class="d-flex align-items-center gap-3">
                            <div class="text-gradient fw-bold">${price?.toLocaleString?.("tr-TR") ?? price} ₺</div>
                            <a href="/Listings/Details/${id}" class="btn btn-sm btn-outline-futuristic px-3">Görüntüle</a>
                        </div>
                    </div>`;
                }).join("");
                
                if (window._lastMyListingsHtml !== html) {
                    $("#myListingsRows").html(html);
                    window._lastMyListingsHtml = html;
                }
            } catch (e) {
                setErr(e?.message ?? String(e));
            }
        }

        /* ── Favorilerim ── */
        async function loadFavorites() {
            try {
                const resIds = await UserApi.get("/api/favorites");
                const ids = resIds?.data || resIds?.Data || [];
                if (!ids.length) {
                    $("#favRows").html('<div class="listing-row-card"><span class="text-muted">Favori ilanınız yok.</span></div>');
                    return;
                }
                const items = [];
                for (const id of ids) {
                    try {
                        const r = await UserApi.get(`/api/listings/${id}`);
                        const d = r?.data || r?.Data;
                        if (d) items.push(d);
                    } catch { }
                }
                if (!items.length) {
                    $("#favRows").html('<div class="listing-row-card"><span class="text-muted">Favori ilanınız yok.</span></div>');
                    return;
                }
                const html = items.map(d => {
                    const id = d.id ?? d.Id;
                    const title = d.title ?? d.Title;
                    const price = d.price ?? d.Price;
                    const city = d.cityName ?? d.CityName ?? "";
                    const district = d.districtName ?? d.DistrictName ?? "";
                    return `<div class="listing-row-card">
                        <div>
                            <div class="fw-semibold text-white">${title}</div>
                            <div class="text-muted small">${city}${district ? " / " + district : ""}</div>
                        </div>
                        <div class="d-flex align-items-center gap-3">
                            <div class="text-gradient fw-bold">${price?.toLocaleString?.("tr-TR") ?? price} ₺</div>
                            <a href="/Listings/Details/${id}" class="btn btn-sm btn-outline-futuristic px-3">Görüntüle</a>
                        </div>
                    </div>`;
                }).join("");
                
                if (window._lastFavoritesHtml !== html) {
                    $("#favRows").html(html);
                    window._lastFavoritesHtml = html;
                }
            } catch (e) {
                setErr(e?.message ?? String(e));
            }
        }

        /* ── Çıkış ── */
        $("#btnLogout").on("click", function () {
            UserAuth.clear();
            window.location.href = "/Account/Login";
        });

        /* ── Init ── */
        (async function init() {
            const token = UserAuth.getToken();
            if (!token) { window.location.href = "/Account/Login"; return; }
            try {
                await loadProfile();
                await loadMyListings();
                await loadFavorites();
                
                // Polling for instant updates on My Listings and Favorites
                setInterval(async () => {
                    if (document.getElementById('tabMyListings').classList.contains('show')) {
                        const oldHtml = $("#myListingsRows").html();
                        await loadMyListings();
                        // Preventing full DOM replace if nothing visually changed could be done here,
                        // but loadMyListings already handles HTML rewriting.
                        // To prevent flicker, we can compare old and new HTML, but loadMyListings is fast.
                    }
                    if (document.getElementById('tabFavorites').classList.contains('show')) {
                        await loadFavorites();
                    }
                }, 1000);
            } catch (e) {
                setErr(e?.message ?? String(e));
            }
        })();
    });
</script>
}