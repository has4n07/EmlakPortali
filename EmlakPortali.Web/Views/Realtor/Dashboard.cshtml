@{
    ViewData["Title"] = "Emlakçı Paneli";
}

<div class="container animate-fade-in-up mt-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2 class="fw-bold" style="font-family: 'Outfit', sans-serif;">
            <i class="bi bi-speedometer2 text-gradient me-2"></i>Emlakçı Paneli
        </h2>
        <a href="/Admin/Listings/Create" class="btn btn-futuristic">
            <i class="bi bi-plus-lg me-1"></i> Yeni İlan Ekle
        </a>
    </div>

    <div id="errBox" class="alert alert-danger d-none glass-panel"></div>

    <div class="row g-4" id="statsRow" style="display: none;">
        <!-- Toplam İlan -->
        <div class="col-md-4">
            <div class="futuristic-card p-4 text-center h-100 d-flex flex-column justify-content-center">
                <i class="bi bi-house-door text-cyan mb-3" style="font-size: 3rem; color: var(--accent-cyan);"></i>
                <h5 class="text-muted text-uppercase tracking-wider">Yayındaki İlanlar</h5>
                <h1 class="display-4 fw-bold text-gradient" id="totalListings">0</h1>
            </div>
        </div>

        <!-- Toplam Görüntülenme (Tıklanma) -->
        <div class="col-md-4">
            <div class="futuristic-card p-4 text-center h-100 d-flex flex-column justify-content-center">
                <i class="bi bi-eye text-purple mb-3" style="font-size: 3rem; color: var(--accent-purple);"></i>
                <h5 class="text-muted text-uppercase tracking-wider">Toplam Görüntülenme</h5>
                <h1 class="display-4 fw-bold text-gradient" id="totalViews">0</h1>
            </div>
        </div>

        <!-- Satış / Pasif -->
        <div class="col-md-4">
            <div class="futuristic-card p-4 text-center h-100 d-flex flex-column justify-content-center">
                <i class="bi bi-check-circle text-pink mb-3" style="font-size: 3rem; color: var(--accent-pink);"></i>
                <h5 class="text-muted text-uppercase tracking-wider">Satılan / Kapatılan</h5>
                <h1 class="display-4 fw-bold text-gradient" id="soldListings">0</h1>
            </div>
        </div>
    </div>
    
    <div class="mt-5">
        <h4 class="mb-3" style="font-family: 'Outfit', sans-serif;">Hızlı İşlemler</h4>
        <div class="glass-panel p-4 d-flex gap-3">
            <a href="/Account/MyListings" class="btn btn-outline-futuristic flex-grow-1 py-3">
                <i class="bi bi-list-ul me-2"></i> İlanlarımı Yönet
            </a>
            <a href="/Account/Me" class="btn btn-outline-futuristic flex-grow-1 py-3">
                <i class="bi bi-person me-2"></i> Profilimi Düzenle
            </a>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        const PrivateApi = (function () {
            const baseUrl = "https://localhost:7293";
            function getToken() { return localStorage.getItem("token"); }

            async function request(method, url, data) {
                const headers = { "Content-Type": "application/json" };
                const token = getToken();
                if (token) headers["Authorization"] = "Bearer " + token;

                const res = await fetch(baseUrl + url, {
                    method: method,
                    headers: headers,
                    body: data ? JSON.stringify(data) : null
                });
                const text = await res.text();
                let json = null; try { json = text ? JSON.parse(text) : null; } catch { }

                if (res.status === 401 || res.status === 403) {
                    window.location.href = "/Account/Login";
                    throw new Error("Oturum süresi doldu veya yetkiniz yok.");
                }

                if (!res.ok) throw new Error(json?.message || json?.Message || text || (res.status + " " + res.statusText));
                return json;
            }
            return {
                get: (url) => request("GET", url)
            };
        })();

        $(async function () {
            const errBox = $("#errBox");
            try {
                const res = await PrivateApi.get("/api/realtordashboard/stats");
                const data = res?.data || res?.Data;
                
                if (data) {
                    $("#totalListings").text(data.totalListings ?? data.TotalListings ?? 0);
                    $("#totalViews").text(data.totalViews ?? data.TotalViews ?? 0);
                    $("#soldListings").text(data.soldListings ?? data.SoldListings ?? 0);
                    $("#statsRow").fadeIn();
                }
            } catch (e) {
                errBox.removeClass("d-none").text(e?.message ?? String(e));
            }
        });
    </script>
}
